---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | Naga Siva Poluri" description="Get in touch with Naga Siva Poluri - AI Integration Engineer, Data Engineer, Full Stack Developer.">
  <div class="page-header">
    <div class="container">
      <span class="section-eyebrow reveal">GET IN TOUCH</span>
      <h1 class="reveal stagger-1">Let's Connect</h1>
      <p class="subtitle reveal stagger-2">Open to Banking, FinTech, AI & Cloud opportunities globally.</p>
    </div>
  </div>

  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <!-- Contact Info -->
        <div class="contact-info-card card-3d reveal">
          <h2>Contact Information</h2>
          <div class="contact-items">
            <div class="contact-item">
              <div class="contact-icon contact-icon-accent">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <h3>Phone</h3>
                <a href="tel:+6581765178">+65 81765178</a>
              </div>
            </div>
            <div class="contact-item">
              <div class="contact-icon contact-icon-teal">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <h3>Email</h3>
                <a href="mailto:npoluri1@gmail.com">npoluri1@gmail.com</a>
              </div>
            </div>
            <div class="contact-item">
              <div class="contact-icon contact-icon-coral">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <h3>Location</h3>
                <p>Singapore</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Availability & Social -->
        <div class="contact-details">
          <div class="availability-card card-3d reveal stagger-1">
            <div class="availability-header">
              <div class="availability-dot"></div>
              <h2>Available for Opportunities</h2>
            </div>
            <p>Open to Banking, FinTech, AI & Cloud opportunities globally. References available on request.</p>
            <p>I'm particularly interested in roles that combine enterprise engineering with AI/ML integration, agentic systems, and intelligent automation.</p>
          </div>

          <div class="social-card card-3d reveal stagger-2">
            <h3>Connect With Me</h3>
            <div class="social-grid">
              <a href="https://github.com/nagasivapoluri" target="_blank" rel="noopener noreferrer" class="social-item">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.605-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/></svg>
                <span>GitHub</span>
              </a>
              <a href="https://linkedin.com/in/nagasivapoluri" target="_blank" rel="noopener noreferrer" class="social-item">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                <span>LinkedIn</span>
              </a>
              <a href="https://twitter.com/nagasivapoluri" target="_blank" rel="noopener noreferrer" class="social-item">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                <span>Twitter / X</span>
              </a>
              <a href="mailto:npoluri1@gmail.com" class="social-item">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <span>Email</span>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="contact-cta reveal">
        <div class="cta-content">
          <h2>Let's Build Something Together</h2>
          <p>Whether it's an AI integration project, enterprise architecture consultation, or a full-time opportunity — I'd love to hear from you.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-section { padding: 2rem 0 6rem; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .contact-info-card { padding: 2.5rem; }

  .contact-info-card h2 {
    font-size: 1.3rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1rem;
  }

  .contact-items { display: flex; flex-direction: column; gap: 1.75rem; }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .contact-icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-icon-accent { background: rgba(139, 92, 246, 0.12); color: var(--accent-light); }
  .contact-icon-teal { background: rgba(20, 184, 166, 0.12); color: var(--teal-light); }
  .contact-icon-coral { background: rgba(249, 115, 22, 0.12); color: var(--coral); }

  .contact-item h3 {
    font-size: 0.9rem;
    margin-bottom: 0.2rem;
    color: var(--text-primary);
  }

  .contact-item a, .contact-item p {
    font-size: 1rem;
    color: var(--teal-light);
    margin: 0;
    font-weight: 500;
  }

  .contact-item a:hover { color: var(--accent-light); }

  .contact-details { display: flex; flex-direction: column; gap: 2rem; }

  .availability-card { padding: 2rem; }

  .availability-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .availability-header h2 { margin: 0; font-size: 1.2rem; border: none; padding: 0; }

  .availability-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--green);
    animation: glow-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .availability-card p { font-size: 0.95rem; line-height: 1.7; margin-bottom: 0.75rem; }
  .availability-card p:last-child { margin-bottom: 0; }

  .social-card { padding: 2rem; }
  .social-card h3 { font-size: 1.1rem; margin-bottom: 1.25rem; }

  .social-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .social-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1.25rem;
    border-radius: var(--radius-sm);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.9rem;
    transition: var(--transition);
  }

  .social-item:hover {
    background: rgba(139, 92, 246, 0.12);
    border-color: var(--border-accent);
    color: var(--accent-light);
    transform: translateY(-2px);
  }

  .contact-cta {
    text-align: center;
    padding: 3rem;
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
  }

  .contact-cta h2 { font-size: 1.8rem; margin-bottom: 1rem; }
  .contact-cta p { font-size: 1.05rem; color: var(--text-muted); max-width: 600px; margin: 0 auto; }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
    .social-grid { grid-template-columns: 1fr; }
  }
</style>
