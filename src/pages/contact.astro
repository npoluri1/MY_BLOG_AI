---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="Contact | Naga Siva Poluri" description="Get in touch with Naga Siva Poluri - AI Integration Engineer, Data Engineer, Full Stack Developer.">
  <div class="contact-page">
    <div class="page-header">
      <div class="container">
        <h1>Contact</h1>
        <p class="subtitle">Open to Banking, FinTech, AI & Cloud opportunities globally.</p>
      </div>
    </div>

    <div class="container content-container">
      <div class="contact-grid">
        <div class="card contact-card">
          <h2>Get In Touch</h2>
          <div class="contact-info">
            <div class="contact-item">
              <span class="contact-icon">📞</span>
              <div>
                <h3>Phone</h3>
                <p>+65 81765178</p>
              </div>
            </div>
            <div class="contact-item">
              <span class="contact-icon">✉</span>
              <div>
                <h3>Email</h3>
                <p>npoluri1@gmail.com</p>
              </div>
            </div>
            <div class="contact-item">
              <span class="contact-icon">📍</span>
              <div>
                <h3>Location</h3>
                <p>Singapore | Open to Global Opportunities</p>
              </div>
            </div>
          </div>
        </div>

        <div class="card contact-card">
          <h2>Availability</h2>
          <p class="availability-text">Available for Banking, FinTech, AI & Cloud opportunities globally.</p>
          <p class="availability-text">References on request.</p>
        </div>
      </div>
    </div>
  </div>

  <style>
    .contact-page {
      padding-bottom: 5rem;
    }

    .page-header {
      background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
      padding: 5rem 0 3rem;
      border-bottom: 1px solid var(--border-color);
      text-align: center;
    }

    .subtitle {
      font-size: 1.2rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 1rem auto 0;
    }

    .content-container {
      margin-top: 4rem;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      max-width: 900px;
      margin: 0 auto;
    }

    .contact-card {
      padding: 2.5rem;
    }

    .contact-card h2 {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.75rem;
    }

    .contact-info {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .contact-item {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .contact-icon {
      font-size: 1.5rem;
      width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg-tertiary);
      border-radius: 12px;
      border: 1px solid var(--border-color);
    }

    .contact-item h3 {
      margin: 0 0 0.25rem;
      font-size: 1rem;
      color: var(--text-primary);
    }

    .contact-item p {
      margin: 0;
      font-size: 1.05rem;
      color: var(--teal-accent);
    }

    .availability-text {
      color: var(--text-secondary);
      font-size: 1.05rem;
      line-height: 1.8;
    }

    @media (max-width: 768px) {
      .contact-grid { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
