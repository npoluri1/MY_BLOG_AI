---
import BaseLayout from '../layouts/BaseLayout.astro';
import TimelineItem from '../components/TimelineItem.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SkillBadge from '../components/SkillBadge.astro';

const experience = [
  {
    company: 'LTA Singapore',
    role: 'AI Integration Engineer',
    period: 'Nov 2025 - Present',
    location: 'Singapore',
    highlight: true,
    description: [
      'Designing and implementing AI-powered solutions for Singapore transport infrastructure',
      'Building enterprise RAG platforms for knowledge management and decision support',
      'Integrating LLMs into existing enterprise workflows and data pipelines',
      'Leading agentic AI initiatives for automated system monitoring and response',
      'Architecting MCP (Model Context Protocol) servers for tool connectivity',
      'Designing multi-agent systems for autonomous operations',
    ],
    tags: ['AI/ML', 'RAG', 'Enterprise Integration', 'Python', 'MCP', 'Agentic AI'],
  },
  {
    company: 'Bank of Singapore',
    role: 'AI Integration Engineer',
    period: 'Sep 2024 - Jul 2025',
    location: 'Singapore',
    highlight: true,
    description: [
      'Built production RAG platform serving internal wealth management teams',
