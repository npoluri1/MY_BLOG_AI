---
import BaseLayout from '../layouts/BaseLayout.astro';
import TimelineItem from '../components/TimelineItem.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SkillBadge from '../components/SkillBadge.astro';

const experience = [
  {
    company: 'LTA Singapore',
    role: 'AI Integration Engineer',
    period: 'Nov 2025 - Present',
    location: 'Singapore',
    highlight: true,
    description: [
      'Designing and implementing AI-powered solutions for Singapore transport infrastructure',
      'Building enterprise RAG platforms for knowledge management and decision support',
      'Integrating LLMs into existing enterprise workflows and data pipelines',
      'Leading agentic AI initiatives for automated system monitoring and response',
    ],
    tags: ['AI/ML', 'RAG', 'Enterprise Integration', 'Python'],
  },
  {
    company: 'Bank of Singapore',
    role: 'AI Integration Engineer',
    period: 'Sep 2024 - Jul 2025',
    location: 'Singapore',
    highlight: true,
    description: [
      'Built production RAG platform serving internal wealth management teams',
      'Designed LLM integration architecture for document analysis and summarization',
      'Implemented vector search capabilities across 10M+ financial documents',
      'Created automated compliance checking system using AI agents',
    ],
    tags: ['RAG', 'LLMs', 'Vector Search', 'Compliance AI'],
  },
  {
    company: 'UOB',
    role: 'Senior Lead Engineer',
    period: 'Jan 2023 - Sep 2024',
    location: 'Singapore',
    description: [
      'Led development of core banking microservices architecture',
      'Designed real-time transaction processing pipelines',
      'Mentored team of 8 engineers across multiple product squads',
      'Implemented CI/CD pipelines reducing deployment time by 60%',
    ],
    tags: ['Microservices', 'Java', 'Event-Driven', 'DevOps'],
  },
  {
    company: 'SingLife',
    role: 'Technical Lead',
    period: 'Aug 2022 - Jan 2023',
    location: 'Singapore',
    description: [
      'Led technical design for digital insurance platform features',
      'Built real-time claims processing system using event-driven architecture',
      'Implemented API gateway handling 10K+ requests per second',
    ],
    tags: ['InsurTech', 'Event-Driven', 'API Design', 'Real-Time'],
  },
  {
    company: 'OCBC Bank',
    role: 'Full Stack Developer',
    period: 'Aug 2021 - Aug 2022',
    location: 'Singapore',
    description: [
      'Developed customer-facing digital banking features',
      'Built React-based dashboards for portfolio management',
      'Implemented real-time notification system using WebSocket',
    ],
    tags: ['React', 'Node.js', 'FinTech', 'WebSocket'],
  },
  {
    company: 'NTUC Income',
    role: 'Full Stack Developer',
    period: 'Sep 2020 - Aug 2021',
    location: 'Singapore',
    description: [
      'Developed policy management system serving 2M+ customers',
      'Built automated underwriting engine using rule-based AI',
      'Optimized database queries reducing response time by 40%',
    ],
    tags: ['Java', 'PostgreSQL', 'Automation', 'Performance'],
  },
  {
    company: 'NCS / LTA ERP2',
    role: 'Senior Java Developer',
    period: 'Aug 2017 - Aug 2020',
    location: 'Singapore',
    description: [
      'Core developer on Singapore ERP2 (Electronic Road Pricing) system',
      'Built high-throughput tolling transaction processing backend',
      'Implemented GNSS-based location services integration',
      'Designed fault-tolerant messaging system using IBM MQ',
    ],
    tags: ['Java', 'IBM MQ', 'GNSS', 'High-Availability'],
  },
];

const aiSkills = [
  { name: 'LLM Integration', color: 'accent' },
  { name: 'RAG Systems', color: 'teal' },
  { name: 'Agentic AI', color: 'coral' },
  { name: 'Vector Databases', color: 'blue' },
  { name: 'Prompt Engineering', color: 'pink' },
  { name: 'LangChain / LlamaIndex', color: 'accent' },
  { name: 'OpenAI / Claude API', color: 'teal' },
  { name: 'Hugging Face', color: 'coral' },
  { name: 'ML Ops', color: 'blue' },
];

const coreSkills = [
  { name: 'Java / Spring Boot', color: 'accent' },
  { name: 'Python', color: 'teal' },
  { name: 'TypeScript / Node.js', color: 'blue' },
  { name: 'React / Next.js', color: 'pink' },
  { name: 'PostgreSQL / MongoDB', color: 'coral' },
  { name: 'AWS / Azure', color: 'accent' },
  { name: 'Docker / Kubernetes', color: 'teal' },
  { name: 'Kafka / RabbitMQ', color: 'blue' },
  { name: 'Git / CI/CD', color: 'pink' },
  { name: 'REST / GraphQL APIs', color: 'coral' },
  { name: 'Microservices', color: 'accent' },
  { name: 'Event-Driven Architecture', color: 'teal' },
