<style>
  .resume-page {
    padding: 6rem 0 4rem;
  }
  .container-narrow {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .resume-header {
    text-align: center;
    margin-bottom: 4rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
    position: relative;
  }
  .print-btn {
    position: absolute;
    top: 0;
    right: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.85rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: var(--transition-fast);
  }
  .print-btn:hover {
    border-color: var(--accent);
    color: var(--accent-light);
  }
  .resume-name {
    font-size: clamp(2rem, 4vw, 2.6rem);
    letter-spacing: 0.05em;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }
  .resume-titles {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--accent-light);
    margin-bottom: 0.9rem;
    font-weight: 600;
  }
  .resume-contact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    font-size: 0.88rem;
    color: var(--text-secondary);
  }

  .resume-section {
    margin-bottom: 2.5rem;
  }
  .resume-section-title {
