      'Processed millions of daily tolling transactions with 99.99% uptime',
      'Built real-time location tracking for ERP2 GNSS system',
    ],
    tags: ['Java', 'IBM MQ', 'GNSS', 'High-Availability', 'PostgreSQL', 'REST APIs'],
  },
