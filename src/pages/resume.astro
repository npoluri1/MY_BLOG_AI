---

<BaseLayout title="Resume | Naga Siva Poluri" description="Professional experience and technical skills of Naga Siva Poluri.">
  <div class="page-header">
    <div class="container">
      <span class="section-eyebrow reveal">EXPERIENCE</span>
      <h1 class="reveal stagger-1">Professional Resume</h1>
      <p class="subtitle reveal stagger-2">15+ years of enterprise solution delivery across Government, Banking, Insurance, and FinTech.</p>
    </div>
  </div>

  <section class="resume-section">
    <div class="container">
      <!-- Professional Summary -->
      <div class="summary-card card-3d reveal">
        <span class="section-eyebrow">PROFESSIONAL SUMMARY</span>
        <p class="summary-text">
          Forward-thinking AI Integration Engineer, Data Engineer & Full Stack Developer with 15+ years of enterprise solution delivery across Singapore's top-tier Government, Banking, Insurance, Transport, and Fintech sectors. Specializing in AI integration, RAG platforms, and agentic architectures with a track record of delivering high-impact solutions at LTA, Bank of Singapore, UOB, and OCBC.
        </p>
      </div>

      <!-- Experience Timeline -->
      <div class="timeline-section">
        <SectionHeader
          eyebrow="CAREER PATH"
          title="Work Experience"
          align="left"
        />
        <div class="timeline">
          {experience.map(exp => (
            <TimelineItem
              company={exp.company}
              role={exp.role}
              period={exp.period}
              location={exp.location}
              description={exp.description}
              tags={exp.tags}
              highlight={exp.highlight}
            />
          ))}
        </div>
      </div>

      <!-- AI Skills -->
      <div class="skills-section">
        <SectionHeader
          eyebrow="AI & INTELLIGENCE"
          title="AI Integration Tech Stack"
          desc="Cutting-edge AI technologies I work with daily."
        />
        <div class="skills-grid reveal">
          {aiSkills.map(skill => (
            <SkillBadge name={skill.name} color={skill.color} />
          ))}
        </div>
      </div>

      <!-- Core Skills -->
      <div class="skills-section">
        <SectionHeader
          eyebrow="CORE TECHNICAL"
          title="Development Skills"
          desc="The full-stack engineering foundation."
        />
        <div class="skills-grid reveal">
          {coreSkills.map(skill => (
            <SkillBadge name={skill.name} color={skill.color} />
          ))}
        </div>
      </div>

      <!-- Education -->
      <div class="education-section">
        <SectionHeader
          eyebrow="EDUCATION"
          title="Academic Background"
        />
        <div class="education-grid">
          <div class="education-card card-3d reveal stagger-1">
            <h3>MBA</h3>
            <p class="edu-school">SMU Hyderabad</p>
            <p class="edu-detail">Master of Business Administration</p>
          </div>
          <div class="education-card card-3d reveal stagger-2">
            <h3>B.E. EEE</h3>
            <p class="edu-school">Anna University</p>
            <p class="edu-detail">Bachelor of Engineering in Electrical & Electronics</p>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="resume-cta reveal">
        <a href="/contact" class="btn btn-primary btn-lg">Get In Touch</a>
        <a href="/" class="btn btn-secondary btn-lg">Back to Home</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .resume-section { padding: 2rem 0 6rem; }

  .summary-card {
    padding: 2rem 2.5rem;
    margin-bottom: 4rem;
  }

  .summary-text {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-top: 0.75rem;
    margin-bottom: 0;
  }

  .timeline-section { margin-bottom: 4rem; }

  .timeline {
    position: relative;
    padding-left: 3rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--accent), var(--teal), var(--accent));
    opacity: 0.3;
  }

  .skills-section { margin-bottom: 4rem; }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }

  .education-section { margin-bottom: 4rem; }

  .education-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .education-card { padding: 2rem; text-align: center; }
  .education-card h3 { font-size: 1.5rem; margin-bottom: 0.5rem; }
  .edu-school { color: var(--accent-light); font-weight: 600; margin-bottom: 0.25rem; }
  .edu-detail { color: var(--text-muted); font-size: 0.9rem; margin: 0; }

  .resume-cta {
    text-align: center;
    display: flex;
    gap: 1rem;
    justify-content: center;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .timeline { padding-left: 2rem; }
    .education-grid { grid-template-columns: 1fr; }
    .resume-cta { flex-direction: column; align-items: center; }
  }
</style>
