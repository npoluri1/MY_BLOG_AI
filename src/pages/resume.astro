const coreSkills = [
  { name: 'Java (Spring Boot, Maven, J2EE)', color: 'accent' },
  { name: 'Python (FastAPI, Pandas, NumPy, Scikit-learn, TensorFlow)', color: 'teal' },
  { name: 'TypeScript / Node.js (NestJS)', color: 'blue' },
