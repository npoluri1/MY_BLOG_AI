---

<BaseLayout title="Resume | Naga Siva Poluri" description="AI Integration Engineer, Data Engineer & Full Stack Developer with 15+ years across Government, Banking, Insurance, and Transport. Specializing in Agentic AI, Enterprise RAG, MCP, and multi-model LLM orchestration.">
  <div class="page-header">
    <div class="container">
      <span class="section-eyebrow reveal">EXPERIENCE</span>
      <h1 class="reveal stagger-1">Professional Resume</h1>
      <p class="subtitle reveal stagger-2">15+ years of enterprise solution delivery across Government, Banking, Insurance, Transport, and FinTech — specializing in Agentic AI, Enterprise RAG, and Full Stack Engineering.</p>
    </div>
  </div>

  <section class="resume-section">
    <div class="container">
      <!-- Professional Summary -->
      <div class="summary-card card-3d reveal">
        <span class="section-eyebrow">PROFESSIONAL SUMMARY</span>
        <p class="summary-text">
          AI Integration Engineer, Data Engineer & Full Stack Developer with 15+ years of enterprise solution delivery across Singapore's top-tier Government, Banking, Insurance, Transport, and Fintech sectors. Specializing in Agentic AI, Enterprise RAG Platforms, MCP implementations, and multi-model LLM orchestration with a proven track record of delivering mission-critical systems at LTA, DBS Bank, UOB, Gxs Bank, and NTUC Income.
        </p>
      </div>

      <!-- Experience Timeline -->
      <div class="timeline-section">
        <SectionHeader
          eyebrow="CAREER PATH"
          title="Work Experience"
          align="left"
        />
        <div class="timeline">
          {experience.map(exp => (
            <TimelineItem
              company={exp.company}
              role={exp.role}
              period={exp.period}
              location={exp.location}
              description={exp.description}
              tags={exp.tags}
              highlight={exp.highlight}
            />
          ))}
        </div>
      </div>

      <!-- Key Projects -->
      <div class="skills-section">
        <SectionHeader
          eyebrow="KEY PROJECTS"
          title="Signature Contributions"
          desc="High-impact systems I've built and led."
        />
        <div class="projects-grid reveal">
          {projects.map(proj => (
            <div class={`project-card project-card--${proj.color}`}>
              <h4 class="project-name">{proj.name}</h4>
              <p class="project-desc">{proj.description}</p>
              <div class="project-tags">
                {proj.tags.map(tag => (
                  <span class="project-tag">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- AI Skills -->
      <div class="skills-section">
        <SectionHeader
          eyebrow="AI & INTELLIGENCE"
          title="AI Engineering & RAG"
          desc="Cutting-edge AI technologies I work with daily."
        />
        <div class="skills-grid reveal">
          {aiSkills.map(skill => (
            <SkillBadge name={skill.name} color={skill.color} />
          ))}
        </div>
      </div>

      <!-- Core Skills -->
      <div class="skills-section">
        <SectionHeader
          eyebrow="CORE TECHNICAL"
          title="Development Skills"
          desc="The full-stack engineering foundation."
        />
        <div class="skills-grid reveal">
          {coreSkills.map(skill => (
            <SkillBadge name={skill.name} color={skill.color} />
          ))}
        </div>
      </div>

      <!-- Domain Knowledge -->
      <div class="skills-section">
        <SectionHeader
          eyebrow="DOMAIN EXPERTISE"
          title="Industry Knowledge"
          desc="Deep understanding of enterprise domains and regulatory requirements."
        />
        <div class="skills-grid reveal">
          {domainKnowledge.map(skill => (
            <SkillBadge name={skill.name} color={skill.color} />
          ))}
        </div>
      </div>

      <!-- Education -->
      <div class="education-section">
        <SectionHeader
          eyebrow="EDUCATION"
          title="Academic Background"
        />
        <div class="education-grid">
          <div class="education-card card-3d reveal stagger-1">
            <h3>MBA</h3>
            <p class="edu-school">Symbiosis International University</p>
            <p class="edu-detail">Master of Business Administration</p>
            <p class="edu-focus">Focus: Technology Management & Strategy</p>
          </div>
          <div class="education-card card-3d reveal stagger-2">
            <h3>B.E. EEE</h3>
            <p class="edu-school">JNTUH (Jawaharlal Nehru Technological University)</p>
            <p class="edu-detail">Bachelor of Engineering in Electrical & Electronics</p>
            <p class="edu-focus">Focus: Embedded Systems & Signal Processing</p>
          </div>
        </div>
      </div>

      <!-- Key Achievements -->
      <div class="achievements-section">
        <SectionHeader
          eyebrow="KEY ACHIEVEMENTS"
          title="Impact & Results"
        />
        <div class="achievements-grid">
          <div class="achievement-card reveal stagger-1">
            <span class="achievement-number">15+</span>
            <span class="achievement-label">Years enterprise solution delivery</span>
          </div>
          <div class="achievement-card reveal stagger-2">
            <span class="achievement-number">10M+</span>
            <span class="achievement-label">Documents indexed in RAG platforms</span>
          </div>
          <div class="achievement-card reveal stagger-3">
            <span class="achievement-number">99.99%</span>
            <span class="achievement-label">Uptime for ERP2 tolling system</span>
          </div>
          <div class="achievement-card reveal stagger-4">
            <span class="achievement-number">900K+</span>
            <span class="achievement-label">OBU devices managed in production</span>
          </div>
          <div class="achievement-card reveal stagger-5">
            <span class="achievement-number">5K+</span>
            <span class="achievement-label">LTA staff served by RAG platform</span>
          </div>
          <div class="achievement-card reveal stagger-6">
            <span class="achievement-number">5M+</span>
            <span class="achievement-label">Daily banking events processed</span>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="resume-cta reveal">
        <a href="/contact" class="btn btn-primary btn-lg">Get In Touch</a>
        <a href="/" class="btn btn-secondary btn-lg">Back to Home</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .resume-section { padding: 2rem 0 6rem; }

  .summary-card {
    padding: 2rem 2.5rem;
    margin-bottom: 4rem;
  }

  .summary-text {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-top: 0.75rem;
    margin-bottom: 0;
  }

  .timeline-section { margin-bottom: 4rem; }

  .timeline {
    position: relative;
    padding-left: 3rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--accent), var(--teal), var(--accent));
    opacity: 0.3;
  }

  .skills-section { margin-bottom: 4rem; }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }

  .education-section { margin-bottom: 4rem; }

  .education-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .education-card { padding: 2rem; text-align: center; }
  .education-card h3 { font-size: 1.5rem; margin-bottom: 0.5rem; }
  .edu-school { color: var(--accent-light); font-weight: 600; margin-bottom: 0.25rem; }
  .edu-detail { color: var(--text-muted); font-size: 0.9rem; margin: 0; }
  .edu-focus { color: var(--text-muted); font-size: 0.85rem; margin: 0.5rem 0 0; font-style: italic; }

  .achievements-section { margin-bottom: 4rem; }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .project-card {
    padding: 1.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: var(--transition-fast);
  }

  .project-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-3px);
  }

  .project-card--accent { border-left: 3px solid var(--accent); }
  .project-card--teal { border-left: 3px solid var(--teal); }
  .project-card--blue { border-left: 3px solid var(--blue); }
  .project-card--coral { border-left: 3px solid var(--coral); }

  .project-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .project-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .project-tag {
    padding: 0.2rem 0.6rem;
    background: rgba(var(--accent-rgb), 0.1);
    border: 1px solid rgba(var(--accent-rgb), 0.2);
    border-radius: 99px;
    font-size: 0.75rem;
    color: var(--accent-light);
  }

  .achievements-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .achievement-card {
    padding: 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-align: center;
    transition: var(--transition-fast);
  }

  .achievement-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  .achievement-number {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    color: var(--accent-light);
    margin-bottom: 0.5rem;
  }

  .achievement-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .resume-cta {
    text-align: center;
    display: flex;
    gap: 1rem;
    justify-content: center;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .timeline { padding-left: 2rem; }
    .education-grid { grid-template-columns: 1fr; }
    .achievements-grid { grid-template-columns: repeat(2, 1fr); }
    .projects-grid { grid-template-columns: 1fr; }
    .resume-cta { flex-direction: column; align-items: center; }
  }
</style>
