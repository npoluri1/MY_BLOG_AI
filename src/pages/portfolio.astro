      { name: 'LangChain', color: 'accent' },
      { name: 'Pinecone', color: 'blue' },
      { name: 'FastAPI', color: 'coral' },
      { name: 'OpenAI', color: 'teal' },
      { name: 'Redis', color: 'coral' },
