---
import BaseLayout from '../layouts/BaseLayout.astro';
import SkillBadge from '../components/SkillBadge.astro';

const projects = [
  {
    title: 'Enterprise RAG Platform',
    category: 'AI / RAG',
    categoryColor: 'teal',
    description: 'Built a production-grade Retrieval Augmented Generation platform serving internal wealth management teams. Implemented vector search across 10M+ financial documents with hybrid dense-sparse retrieval and reranking.',
    image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&h=400&fit=crop',
    tech: [
      { name: 'Python', color: 'teal' },
      { name: 'LangChain', color: 'accent' },
      { name: 'Pinecone', color: 'blue' },
      { name: 'FastAPI', color: 'coral' },
    ],
    link: '#',
  },
  {
    title: 'Agentic AI Platform',
    category: 'AGENTIC AI',
    categoryColor: 'accent',
    description: 'Designed and built a multi-agent AI platform for autonomous system monitoring and self-healing. Implemented tool orchestration, memory management, and guardrails for production-safe agent execution.',
    image: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?w=600&h=400&fit=crop',
    tech: [
      { name: 'Claude API', color: 'accent' },
      { name: 'TypeScript', color: 'blue' },
      { name: 'Redis', color: 'coral' },
      { name: 'Docker', color: 'teal' },
    ],
    link: '#',
  },
  {
    title: 'Singapore ERP2 Tolling System',
    category: 'TRANSPORT / GNSS',
    categoryColor: 'coral',
    description: 'Core developer on Singapore\'s next-generation Electronic Road Pricing system. Built high-throughput tolling transaction processing with GNSS-based location services and fault-tolerant IBM MQ messaging.',
    image: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=600&h=400&fit=crop',
    tech: [
      { name: 'Java', color: 'coral' },
      { name: 'IBM MQ', color: 'accent' },
      { name: 'GNSS', color: 'teal' },
      { name: 'PostgreSQL', color: 'blue' },
    ],
    link: '#',
  },
  {
    title: 'Digital Banking Microservices',
    category: 'FINTECH',
    categoryColor: 'pink',
    description: 'Led development of core banking microservices architecture at UOB, designing real-time transaction processing pipelines and implementing CI/CD reducing deployment time by 60%.',
    image: 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=600&h=400&fit=crop',
    tech: [
      { name: 'Java', color: 'coral' },
      { name: 'Kubernetes', color: 'accent' },
      { name: 'Kafka', color: 'teal' },
      { name: 'React', color: 'blue' },
    ],
    link: '#',
  },
  {
    title: 'Smart Claims Processing',
    category: 'INSURTECH',
    categoryColor: 'blue',
    description: 'Built real-time claims processing system at SingLife using event-driven architecture, implementing automated underwriting and API gateway handling 10K+ requests per second.',
    image: 'https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=600&h=400&fit=crop',
    tech: [
      { name: 'Node.js', color: 'teal' },
      { name: 'Event-Driven', color: 'accent' },
      { name: 'WebSocket', color: 'blue' },
      { name: 'MongoDB', color: 'coral' },
    ],
    link: '#',
  },
];
---

<BaseLayout title="Portfolio | Naga Siva Poluri" description="Featured projects and case studies by Naga Siva Poluri.">
  <div class="page-header">
    <div class="container">
      <span class="section-eyebrow">PORTFOLIO</span>
      <h1>Featured Projects</h1>
      <p class="subtitle">A selection of enterprise AI and full-stack projects I've delivered.</p>
    </div>
  </div>

  <section class="portfolio-section">
    <div class="container">
      <div class="project-grid">
        {projects.map((project) => (
          <article class="project-card">
            <div class="project-image">
              <img src={project.image} alt={project.title} loading="lazy" />
            </div>
            <div class="project-body">
              <span class={`project-badge badge-${project.categoryColor}`}>{project.category}</span>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <div class="project-tech">
                {project.tech.map((t) => (
                  <SkillBadge name={t.name} color={t.color} />
                ))}
              </div>
              <a href={project.link} class="project-link">
                View Project Details
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 8rem 0 3rem;
    text-align: center;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: 0.75rem;
  }

  .subtitle {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .portfolio-section {
    padding: 0 0 6rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .project-card {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .project-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-md);
  }

  .project-image {
    position: relative;
    min-height: 280px;
    overflow: hidden;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .project-card:hover .project-image img {
    transform: scale(1.04);
  }

  .project-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .project-badge {
    display: inline-block;
    width: fit-content;
    margin-bottom: 0.75rem;
  }

  .project-body h3 {
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
  }

  .project-body p {
    font-size: 0.92rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--accent-light);
    transition: color 0.2s ease;
  }

  .project-link:hover {
    color: var(--teal-light);
  }

  @media (max-width: 768px) {
    .project-card {
      grid-template-columns: 1fr;
    }

    .project-image {
      min-height: 200px;
    }

    .project-body {
      padding: 1.5rem;
    }
  }
</style>
