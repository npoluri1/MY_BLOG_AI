    link: '#',
  },
  {
    title: 'Agentic AI Platform',
    category: 'AGENTIC AI',
    categoryColor: 'accent',
    description: 'Designed and built a multi-agent AI platform for autonomous system monitoring and self-healing. Implemented tool orchestration, memory management, and guardrails for production-safe agent execution.',
