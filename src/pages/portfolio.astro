// ---------- GitHub Open Source ----------
// GitHub username: live repos are loaded at build time via the GitHub REST API.
const GITHUB_USER = 'npoluri1';
const GH_API = `https://api.github.com/users/${GITHUB_USER}/repos?per_page=100&sort=updated`;

// Language → dot color (GitHub palette)
const GH_LANG_COLORS = {
  JavaScript: '#f1e05a',
  TypeScript: '#3178c6',
  Python: '#3572A5',
  Vue: '#41b883',
  Go: '#00ADD8',
  Astro: '#FF5D01',
  Java: '#b07219',
  'C++': '#f34b7d',
  C: '#555555',
  PHP: '#4F5D95',
  Ruby: '#701516',
  HCL: '#623fff',
  Shell: '#89e051',
  HTML: '#e34c26',
  Puppet: '#302B6D',
  Dockerfile: '#384d54',
};

function ghLangColor(lang) {
  return GH_LANG_COLORS[lang] || 'var(--accent)';
}

function timeAgo(dateStr) {
  if (!dateStr) return '';
  const then = new Date(dateStr);
  if (isNaN(then.getTime())) return '';
  const now = new Date();
  const diffSec = Math.floor((now - then) / 1000);
  if (diffSec < 0) return 'just now';
  if (diffSec < 60) return 'just now';
  if (diffSec < 3600) return `${Math.floor(diffSec / 60)}m ago`;
  if (diffSec < 86400) return `${Math.floor(diffSec / 3600)}h ago`;
  if (diffSec < 604800) return `${Math.floor(diffSec / 86400)}d ago`;
  if (diffSec < 2592000) return `${Math.floor(diffSec / 604800)}w ago`;
  if (diffSec < 31536000) return `${Math.floor(diffSec / 2592000)}mo ago`;
  return `${Math.floor(diffSec / 31536000)}y ago`;
}

let githubRepos = [];
let githubSummary = { total: 0, stars: 0, forks: 0, languages: 0 };
let githubFetchFailed = false;

try {
  const res = await fetch(GH_API, { headers: { Accept: 'application/vnd.github+json', 'User-Agent': 'my-blog-ai-build' } });
  if (res.ok) {
    const data = await res.json();
    if (Array.isArray(data)) {
      const active = data.filter(r => !r.fork && !r.archived)
        .sort((a, b) => (b.stargazers_count - a.stargazers_count) || (new Date(b.updated_at) - new Date(a.updated_at)));
      const forks = data.filter(r => r.fork && !r.archived)
        .sort((a, b) => new Date(b.updated_at) - new Date(a.updated_at));
      const archived = data.filter(r => r.archived)
        .sort((a, b) => new Date(b.updated_at) - new Date(a.updated_at));
      githubRepos = [...active, ...forks, archived].slice(0, 60);

      const langs = new Set();
      for (const r of githubRepos) {
        if (r.language) langs.add(r.language);
        githubSummary.stars += r.stargazers_count || 0;
        githubSummary.forks += r.forks_count || 0;
      }
      githubSummary.total = githubRepos.length;
      githubSummary.languages = langs.size;
    } else {
      githubFetchFailed = true;
    }
  } else {
    githubFetchFailed = true;
  }
} catch (err) {
  githubFetchFailed = true;
}

const githubProfileUrl = `https://github.com/${GITHUB_USER}`;
---

<BaseLayout
  title="Portfolio | Naga Siva Poluri"
  description="Featured projects: Agentic AI platform, Enterprise RAG intelligence, LTA transport AI, Bank of Singapore loan AI, UOB data platform."
>
  <div class="page-header">
    <div class="container">
      <span class="section-eyebrow">PORTFOLIO</span>
      <h1>Featured Work</h1>
      <p class="subtitle">Self-built AI platforms plus 15 years of enterprise delivery across Singapore's Government, Banking, Insurance &amp; Fintech sectors.</p>
    </div>
  </div>

  <section class="portfolio-section">
    <div class="container">
      <div class="project-stats reveal">
        <div class="stat-item">
          <span class="stat-number">2</span>
          <span class="stat-label">Self-built AI Platforms</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">15+</span>
          <span class="stat-label">Years Enterprise Delivery</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">8</span>
          <span class="stat-label">Industries Served</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">99.9%</span>
          <span class="stat-label">Production Uptime</span>
        </div>
      </div>

      <div class="project-grid">
        {projects.map((project) => (
          <article class="project-card">
            <div class="project-image">
              <img src={project.image} alt={project.title} loading="lazy" />
            </div>
            <div class="project-body">
              <div class="project-badge-row">
                <span class={`project-badge badge-${project.categoryColor}`}>{project.category}</span>
                <span class="project-period">{project.period}</span>
              </div>
              <h3>{project.title}</h3>
              <p>{project.description}</p>

              <div class="project-highlights">
                <h4>Key Achievements</h4>
                <ul>
                  {project.highlights.map(highlight => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              </div>

              <div class="project-tech">
                {project.tech.map((t) => (
                  <SkillBadge name={t.name} color={t.color} />
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- GitHub Open Source Section -->
  <section class="os-section reveal">
    <div class="container">
      <SectionHeader
        eyebrow="OPEN SOURCE"
        title="GitHub Contributions"
        desc={`A live mirror of all repositories on github.com/${GITHUB_USER} — fetched at build time.`}
      />

      {githubRepos.length === 0 ? (
        <div class="os-empty">
          <p>The GitHub API was unreachable from the build environment, or no public repositories are available under this handle.</p>
          <p class="os-hint">If you forked this template, set <code>GITHUB_USER</code> in <code>src/pages/portfolio.astro</code> to your own GitHub handle.</p>
          <a href={githubProfileUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            View profile on GitHub →
          </a>
        </div>
      ) : (
        <>
          <div class="os-toolbar">
            <div class="os-summary">
              <span class="os-stat"><strong>{githubSummary.total}</strong> repos</span>
              <span class="os-stat"><strong>{githubSummary.languages}</strong> languages</span>
              <span class="os-stat"><strong>{githubSummary.stars}</strong> ★</span>
              <span class="os-stat"><strong>{githubSummary.forks}</strong> ⑂</span>
            </div>
            <a href={githubProfileUrl} target="_blank" rel="noopener noreferrer" class="os-profile-link">
              github.com/{GITHUB_USER} ↗
            </a>
          </div>

          <ol class="os-grid" aria-label="GitHub repositories list">
            {githubRepos.map((repo, idx) => (
              <li class="os-card reveal stagger-{(idx % 8) + 1}">
                <a
                  href={repo.html_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="os-link"
                  aria-label={`View ${repo.name} on GitHub. ${repo.stargazers_count} stars.`}
                >
                  {(repo.fork || repo.archived) && (
                    <span class="os-tag" data-kind={repo.archived ? 'archived' : 'fork'}>
                      {repo.archived ? 'archived' : 'fork'}
                    </span>
                  )}
                  <header class="os-card-header">
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="os-icon">
                      <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.25.25 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z" />
                    </svg>
                    <h3 class="os-title">{repo.name}</h3>
                  </header>
                  <p class="os-desc">{repo.description || '—'}</p>
                  {repo.topics && repo.topics.length > 0 && (
                    <div class="os-topics">
                      {repo.topics.slice(0, 3).map((topic) => (
                        <span class="os-topic">{topic}</span>
                      ))}
                    </div>
                  )}
                  <footer class="os-meta">
                    {repo.language && (
                      <span class="os-lang">
                        <span class="os-lang-dot" style={`background:${ghLangColor(repo.language)}`}></span>
                        {repo.language}
                      </span>
                    )}
                    <span class="os-meta-item" title={`${repo.stargazers_count} stars`}>★ {repo.stargazers_count}</span>
                    <span class="os-meta-item" title={`${repo.forks_count} forks`}>⑂ {repo.forks_count}</span>
                    <span class="os-meta-time">{timeAgo(repo.updated_at)}</span>
                  </footer>
                </a>
              </li>
            ))}
          </ol>

          <p class="os-foot">
            Showing {githubRepos.length} public repos.
            <a href={githubProfileUrl + '?tab=repositories'} target="_blank" rel="noopener noreferrer">View the full archive on GitHub →</a>
          </p>
        </>
      )}
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-card">
        <h2>Have a Project in Mind?</h2>
        <p>I'm available for AI integration consulting, enterprise architecture, and full-stack development projects.</p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary">Get In Touch</a>
          <a href="/resume" class="btn btn-secondary">View Resume</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 8rem 0 3rem;
    text-align: center;
  }
  .page-header h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: 0.75rem;
  }
  .subtitle {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 700px;
    margin: 0 auto;
  }

  .portfolio-section { padding: 0 0 4rem; }

  .project-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 4rem;
    padding: 2rem;
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
  }
  .stat-item { text-align: center; }
  .stat-number {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    color: var(--accent-light);
    margin-bottom: 0.25rem;
  }
  .stat-label {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .project-card {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .project-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-md);
  }

  .project-image {
    position: relative;
    min-height: 320px;
    overflow: hidden;
  }
  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .project-card:hover .project-image img { transform: scale(1.04); }

  .project-body { padding: 2rem; display: flex; flex-direction: column; }
  .project-badge-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .project-badge {
    display: inline-block;
    width: fit-content;
  }
  .project-period {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--accent-light);
    background: rgba(139, 92, 246, 0.1);
    padding: 0.2rem 0.65rem;
    border-radius: var(--radius-full);
  }
  .project-body h3 {
    font-size: 1.35rem;
    margin-bottom: 0.6rem;
  }
  .project-body p {
    font-size: 0.92rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .project-highlights { margin-bottom: 1.25rem; }
  .project-highlights h4 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  .project-highlights ul { list-style: none; padding: 0; margin: 0; }
