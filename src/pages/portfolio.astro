    tech: [
      { name: 'Python', color: 'teal' },
      { name: 'Apache Spark', color: 'coral' },
      { name: 'PostgreSQL', color: 'blue' },
      { name: 'AWS', color: 'accent' },
      { name: 'Docker', color: 'teal' },
      { name: 'ETL', color: 'pink' },
    ],
