    left: 0;
    color: var(--teal-light);
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--accent-light);
    transition: color 0.2s ease;
  }

  .project-link:hover {
    color: var(--teal-light);
  }

  .cta-section {
    padding: 4rem 0 6rem;
  }

