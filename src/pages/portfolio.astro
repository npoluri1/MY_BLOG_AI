    ],
    link: '#',
  },
  {
    title: 'Singapore ERP2 Tolling System',
    category: 'TRANSPORT / GNSS',
    categoryColor: 'coral',
    description: 'Core developer on Singapore\'s next-generation Electronic Road Pricing system. Built high-throughput tolling transaction processing with GNSS-based location services and fault-tolerant IBM MQ messaging.',
    image: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=600&h=400&fit=crop',
    tech: [
      { name: 'Java', color: 'coral' },
      { name: 'IBM MQ', color: 'accent' },
      { name: 'GNSS', color: 'teal' },
      { name: 'PostgreSQL', color: 'blue' },
      { name: 'REST APIs', color: 'pink' },
      { name: 'High-Availability', color: 'coral' },
    ],
    highlights: [
      '99.99% uptime for mission-critical system',
      'Millions of daily transactions',
      'Real-time GNSS location tracking',
      'Fault-tolerant messaging architecture',
    ],
    link: '#',
  },
  {
    title: 'Digital Banking Microservices',
    category: 'FINTECH',
    categoryColor: 'pink',
    description: 'Led development of core banking microservices architecture at UOB, designing real-time transaction processing pipelines and implementing CI/CD reducing deployment time by 60%.',
    image: 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=600&h=400&fit=crop',
    tech: [
      { name: 'Java', color: 'coral' },
      { name: 'Kubernetes', color: 'accent' },
      { name: 'Kafka', color: 'teal' },
      { name: 'React', color: 'blue' },
      { name: 'Spring Boot', color: 'teal' },
