---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = [
  {
    title: 'Enterprise RAG Platform',
    description: 'Built a production-grade Retrieval Augmented Generation platform serving internal wealth management teams. Implemented vector search across 10M+ financial documents.',
    image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&h=400&fit=crop',
    href: '/portfolio',
    tag: 'AI / RAG'
  },
  {
    title: 'Agentic AI Platform',
    description: 'Designed and built a multi-agent AI platform for autonomous system monitoring and self-healing with tool orchestration and guardrails.',
    image: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?w=600&h=400&fit=crop',
    href: '/portfolio',
    tag: 'AGENTIC AI'
  }
];
---

<BaseLayout title="Naga Siva Poluri | AI Integration Engineer & Full Stack Developer">
  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-name">NAGA SIVA POLURI</h1>
      <p class="hero-tagline">AI INTEGRATION ENGINEER &bull; DATA ENGINEER &bull; FULL STACK DEVELOPER &bull; AGENTIC AI SPECIALIST</p>
      <p class="hero-desc">
        A software engineer with a balanced left and right brain, specializing in AI integration, RAG systems, agentic architectures, and full-stack enterprise applications.
      </p>
      <div class="hero-ctas">
        <a href="/blog" class="btn btn-primary">Read My Blog</a>
        <a href="/portfolio" class="btn btn-secondary">View Portfolio</a>
        <a href="/resume" class="btn btn-outline">Resume</a>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Featured Projects</h2>
        <a href="/portfolio" class="section-link">View All Projects →</a>
      </div>
      <div class="projects-grid">
        {projects.map(project => (
          <a href={project.href} class="project-card">
            <img src={project.image} alt={project.title} class="project-image" loading="lazy" />
            <div class="project-content">
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <span class="project-link">Details →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Blog Posts -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Latest Blog Posts</h2>
        <a href="/blog" class="section-link">Read All Posts →</a>
      </div>
      <div class="posts-list">
        {posts.map(post => (
          <a href={`/blog/${post.id}`} class="post-card">
            <div class="post-meta">
              <span class="post-date">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            </div>
            <h3 class="post-title">{post.data.title}</h3>
            <p class="post-desc">{post.data.description}</p>
            <span class="post-link">Read Post →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 8rem 0 4rem;
    text-align: center;
  }

  .hero-name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
    line-height: 1.1;
  }

  .hero-tagline {
    font-size: clamp(0.85rem, 1.5vw, 1rem);
    color: var(--text-muted);
    letter-spacing: 0.15em;
    font-weight: 600;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
  }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--text-secondary);
    max-width: 650px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .section {
    padding: 4rem 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .section-header h2 {
    font-size: 1.5rem;
    margin: 0;
  }

  .section-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent-light);
    text-decoration: none;
  }

  .section-link:hover {
    text-decoration: underline;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .project-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: var(--transition);
  }

  .project-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .project-image {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
  }

  .project-content {
    padding: 1.5rem;
  }

  .project-content h3 {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }

  .project-content p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .project-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-light);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-card {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
    transition: var(--transition-fast);
  }

  .post-card:first-child {
    padding-top: 0;
  }

  .post-card:hover {
    padding-left: 1rem;
  }

  .post-meta {
    margin-bottom: 0.5rem;
  }

  .post-date {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .post-title {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
    line-height: 1.4;
  }

  .post-card:hover .post-title {
    color: var(--accent-light);
  }

  .post-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .post-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-light);
  }

  @media (max-width: 768px) {
    .hero { padding: 6rem 0 3rem; }
    .projects-grid { grid-template-columns: 1fr; }
    .section-header { flex-direction: column; gap: 0.5rem; align-items: flex-start; }
  }
</style>
