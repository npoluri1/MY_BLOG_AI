---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ThreeConstellation from '../../components/ThreeConstellation.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths({ paginate }) {
  const allPosts = (await getCollection('blog'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return paginate(allPosts, { pageSize: 10 });
}

const { page } = Astro.props;
const { data: posts, currentPage, totalPages, url, lastPage } = page;

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalCount = allPosts.length;

function excerptSearchable(post) {
  const t = (post.data.title || '').toLowerCase();
  const d = (post.data.description || '').toLowerCase();
  const c = (post.data.primaryCategory || '').toLowerCase();
  const cat = (post.data.category || []).join(' ').toLowerCase();
  const tags = (post.data.tags || []).join(' ').toLowerCase();
  return t + ' ' + d + ' ' + c + ' ' + cat + ' ' + tags;
}

function categoryOf(post) {
  return post.data.primaryCategory
    || (post.data.tags && post.data.tags[0])
    || (post.data.category && post.data.category[0])
    || 'Essay';
}

function formatDate(d) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

function formatDateShort(d) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Constellation payload: all posts so the 3D view always reflects the full archive.
const constellationPosts = allPosts.map(p => ({
  slug: p.id.replace(/\.md$/, ''),
  title: p.data.title,
  tags: p.data.tags || p.data.category || [],
  primaryCategory: categoryOf(p),
  pubDate: formatDateShort(p.data.pubDate),
}));

// Top tags across the full corpus (used for filter pills).
const tagCounts = {};
for (const p of allPosts) {
  const t = categoryOf(p);
  tagCounts[t] = (tagCounts[t] || 0) + 1;
}
const topTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);

// Items for the server-rendered (paginated) archive list.
const archiveItems = posts.map(post => ({
  slug: post.id.replace(/\.md$/, ''),
  title: post.data.title,
  description: post.data.description || '',
  pubDateIso: post.data.pubDate.toISOString(),
  pubDateLabel: formatDate(post.data.pubDate),
  primaryCategory: categoryOf(post),
  catSlug: categoryOf(post).toLowerCase().replace(/\s+/g, '-'),
  searchable: excerptSearchable(post),
}));

// Minimal corpus for client-side full-archive search/filter.
const corpus = allPosts.map(p => ({
  slug: p.id.replace(/\.md$/, ''),
  title: p.data.title,
  description: p.data.description || '',
  primaryCategory: categoryOf(p),
  catSlug: categoryOf(p).toLowerCase().replace(/\s+/g, '-'),
  pubDateIso: p.data.pubDate.toISOString(),
  pubDateLabel: formatDate(p.data.pubDate),
  searchable: excerptSearchable(p),
}));

// Smart pagination: 1, [gap], neighbors, [gap], last.
function getPageNumbers(current, total) {
  if (total <= 7) {
    const p = [];
    for (let i = 1; i <= total; i++) p.push(i);
    return p;
  }
  const pages = [1];
  const left = Math.max(2, current - 1);
  const right = Math.min(total - 1, current + 1);
  if (left > 2) pages.push('...');
  for (let i = left; i <= right; i++) pages.push(i);
  if (right < total - 1) pages.push('...');
  pages.push(total);
  return pages;
}

const pageNumbers = getPageNumbers(currentPage, totalPages);

const pageTitle = currentPage === 1
  ? 'Constellation | Naga Siva Poluri Archive'
  : `Constellation — Page ${currentPage} of ${totalPages} | Naga Siva Poluri`;

const pageDescription = currentPage === 1
  ? 'A navigable 3D universe of writings on AI, agentic systems, agile, governance, and the engineering mind — curated by Naga Siva Poluri.'
  : `Page ${currentPage} of ${totalPages}: AI, agentic systems, agile, and engineering articles by Naga Siva Poluri.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="blog-index-page">
    <div class="page-header">
      <div class="container">
        <span class="section-eyebrow reveal">THE EMPTYING THE CUP ARCHIVE</span>
        <h1 class="reveal stagger-1">A Constellation of Ideas</h1>
        <p class="subtitle reveal stagger-2">
          {totalCount} essays on AI, agentic systems, agile, governance, and the engineer's evolution —
          curated by Naga Siva Poluri and arranged as a navigable 3D universe.
        </p>
        <div class="header-stats reveal stagger-3">
          <span class="stat"><strong>{totalCount}</strong> essays</span>
          <span class="stat-divider"></span>
          <span class="stat"><strong>{topTags.length}</strong> topics</span>
          <span class="stat-divider"></span>
          <span class="stat"><strong>{currentPage}</strong> / <strong>{totalPages}</strong> pages</span>
        </div>
      </div>
    </div>

    {currentPage === 1 && (
      <section class="constellation-wrap reveal stagger-4">
        <div class="container container-wide">
          <ThreeConstellation posts={constellationPosts} />
        </div>
      </section>
    )}

    <section class="archive-section">
      <div class="container">
        <div class="archive-header">
          <h2>The Written Archive</h2>
          <p>Browse, search, and filter every article chronologically.</p>
        </div>

        <div class="archive-controls reveal">
          <div class="archive-search-row">
            <div class="archive-search-input-wrap">
              <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <input id="archiveSearch" type="search" placeholder={`Search ${totalCount} essays by title, description, or topic…`} autocomplete="off" aria-label="Search articles" />
              <button id="archiveSearchClear" class="archive-search-clear" type="button" aria-label="Clear search">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            </div>
            <div class="archive-result-count" id="archiveResultCount" aria-live="polite">
              Showing {archiveItems.length} of {archiveItems.length}
            </div>
          </div>

          <div class="archive-tag-row">
            <button type="button" class="archive-tag archive-tag-clear" id="archiveClearAll" hidden>
              <span class="archive-tag-name">Clear</span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
            {topTags.map(([name, count]) => (
              <button type="button" class="archive-tag" data-tag={name.toLowerCase().replace(/\s+/g, '-')}>
                <span class="archive-tag-name">{name}</span>
                <span class="archive-tag-count">{count}</span>
              </button>
            ))}
          </div>
        </div>

        <ol class="archive-list" id="archiveList" data-mode="browse">
          {archiveItems.map(item => (
            <li class="archive-item" data-cat={item.catSlug} data-search={item.searchable}>
              <a href={`/blog/${item.slug}`} class="archive-link">
                <div class="archive-meta">
                  <time datetime={item.pubDateIso}>{item.pubDateLabel}</time>
                  <span class="archive-cat">{item.primaryCategory}</span>
                </div>
                <h3 class="archive-title">{item.title}</h3>
                <p class="archive-desc">{item.description}</p>
                <span class="archive-arrow">Read →</span>
              </a>
            </li>
          ))}
        </ol>

        <nav class="pagination" id="archivePagination" aria-label="Blog pagination">
          {url.prev ? (
            <a href={url.prev} class="pagination-btn pagination-edge" rel="prev" aria-label="Previous page">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              <span>Prev</span>
            </a>
          ) : (
            <span class="pagination-btn pagination-edge pagination-disabled" aria-disabled="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              <span>Prev</span>
            </span>
          )}

          {currentPage > 3 && (
            <a href="/blog" class="pagination-btn pagination-jump" aria-label="First page">First</a>
          )}

          <div class="pagination-pages" id="paginationPages">
            {pageNumbers.map(num => (
              num === '...' ? (
                <span class="pagination-ellipsis" aria-hidden="true">···</span>
              ) : (
                <a
                  href={num === 1 ? '/blog' : `/blog/${num}`}
                  class={`pagination-page ${num === currentPage ? 'pagination-current' : ''}`}
                  aria-current={num === currentPage ? 'page' : undefined}
                  aria-label={`Page ${num}${num === currentPage ? ' (current)' : ''}`}
                >
                  {num}
                </a>
              )
            ))}
          </div>

          {currentPage < lastPage && (
            <a href={`/blog/${lastPage}`} class="pagination-btn pagination-jump" aria-label="Last page">Last</a>
          )}

          {url.next ? (
            <a href={url.next} class="pagination-btn pagination-edge" rel="next" aria-label="Next page">
              <span>Next</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          ) : (
            <span class="pagination-btn pagination-edge pagination-disabled" aria-disabled="true">
              <span>Next</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </span>
          )}
        </nav>

        <div id="archiveEmptyState" class="archive-empty-state" hidden>
          <div class="empty-illustration" aria-hidden="true">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          </div>
          <h3 class="empty-title">No essays match the current filters</h3>
          <p class="empty-desc">Try a different keyword, remove a tag, or browse the full archive below.</p>
          <button type="button" id="archiveEmptyReset" class="archive-empty-reset">Reset filters</button>
        </div>
      </div>
    </section>
  </div>

  <script id="blog-corpus" type="application/json" set:html={JSON.stringify(corpus).replace(/</g, '\\u003c').replace(/>/g, '\\u003e')} />
</BaseLayout>

<script is:inline>
  // Blog archive client-side controller.
  // Two modes: "browse" = server-rendered 10-item page + pagination;
  //            "search" = full-corpus query against #blog-corpus, hides page list + pagination.
  // State sync: ?q=text  →  #tag-cat1,cat2  →  defaults to browse.
  (function () {
    if (typeof document === 'undefined') return;

    function ready(fn) {
      if (document.readyState !== 'loading') fn();
      else document.addEventListener('DOMContentLoaded', fn);
    }

    ready(function () {
      const list = document.getElementById('archiveList');
      const pagination = document.getElementById('archivePagination');
      const searchInput = document.getElementById('archiveSearch');
      const clearBtn = document.getElementById('archiveSearchClear');
      const clearAll = document.getElementById('archiveClearAll');
      const countEl = document.getElementById('archiveResultCount');
      const emptyState = document.getElementById('archiveEmptyState');
      const emptyReset = document.getElementById('archiveEmptyReset');
      const tagButtons = document.querySelectorAll('.archive-tag:not(.archive-tag-clear)');
      const corpusEl = document.getElementById('blog-corpus');

      if (!list || !corpusEl) return;

      let corpus = [];
      try { corpus = JSON.parse(corpusEl.textContent || '[]'); } catch (e) { corpus = []; }

      // Cache originals from paginated render once.
      // Store both live DOM references AND the outerHTML string so we can
      // re-cache references after restoreOriginalList() replaces innerHTML.
      const originalItems = Array.from(list.querySelectorAll('.archive-item')).map(li => ({
        el: li,
        outerHTML: li.outerHTML,
        titleEl: li.querySelector('.archive-title'),
        descEl: li.querySelector('.archive-desc'),
        cat: (li.dataset.cat || '').toLowerCase(),
        titleText: (li.querySelector('.archive-title') || {}).textContent || '',
        descText: (li.querySelector('.archive-desc') || {}).textContent || '',
        search: li.dataset.search || '',
      }));

      const totalInCorpus = corpus.length;
      let query = '';
      let activeTags = new Set();

      function normalizeTag(t) {
        return (t || '').toLowerCase().replace(/\s+/g, '-');
      }

      function escapeHtml(s) {
        return (s || '').replace(/[&<>"']/g, c => ({
          '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
        }[c]));
      }

      function escapeRegex(s) {
        return (s || '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      }

      function resetHighlight(el, original) {
        if (el) el.textContent = original;
      }

      function highlightText(text, q) {
        // Returns safe HTML: <mark>wrapped matches</mark>, escaped content otherwise.
        if (!q) return escapeHtml(text);
        const safe = escapeHtml(text);
        const re = new RegExp('(' + escapeRegex(q) + ')', 'ig');
        return safe.replace(re, '<mark class="archive-mark">$1</mark>');
      }

      function applyHighlights(li, q) {
        const titleEl = li.querySelector('.archive-title');
        const descEl = li.querySelector('.archive-desc');
        if (titleEl) titleEl.innerHTML = highlightText(titleEl.dataset.original || titleEl.textContent, q);
        if (descEl) descEl.innerHTML = highlightText(descEl.dataset.original || descEl.textContent, q);
      }

      function clearHighlights() {
        for (const { titleEl, descEl, titleText, descText } of originalItems) {
          if (titleEl) {
            titleEl.textContent = titleText;
            titleEl.dataset.original = titleText;
          }
          if (descEl) {
            descEl.textContent = descText;
            descEl.dataset.original = descText;
          }
        }
      }

      function ensureOriginals() {
        for (const { titleEl, descEl, titleText, descText } of originalItems) {
          if (titleEl && !titleEl.dataset.original) titleEl.dataset.original = titleText;
          if (descEl && !descEl.dataset.original) descEl.dataset.original = descText;
        }
      }

      function setMode(mode) {
        // mode: 'browse' (server page) or 'search' (full-corpus results)
        if (!list) return;
        if (mode === 'search') {
          list.dataset.mode = 'search';
          if (pagination) pagination.hidden = true;
          list.hidden = false;
        } else {
          list.dataset.mode = 'browse';
          if (pagination) pagination.hidden = false;
        }
      }

      function renderSearchResults(matches, q) {
        // Build a fresh <ol> children from corpus matches. Preserve highlight passthrough.
        // Apply .archive-item-appear for a smooth fade-in on freshly-rendered results.
        const safeQ = (q || '').trim();
        list.innerHTML = matches.map(m => {
          const titleHtml = highlightText(m.title, safeQ);
          const descHtml = highlightText(m.description, safeQ);
          return (
            '<li class="archive-item archive-item-appear" data-cat="' + escapeHtml(m.catSlug) + '">' +
              '<a href="/blog/' + escapeHtml(m.slug) + '" class="archive-link">' +
                '<div class="archive-meta">' +
                  '<time datetime="' + escapeHtml(m.pubDateIso) + '">' + escapeHtml(m.pubDateLabel) + '</time>' +
                  '<span class="archive-cat">' + escapeHtml(m.primaryCategory) + '</span>' +
                '</div>' +
                '<h3 class="archive-title">' + titleHtml + '</h3>' +
                '<p class="archive-desc">' + descHtml + '</p>' +
                '<span class="archive-arrow">Read →</span>' +
              '</a>' +
            '</li>'
          );
        }).join('');
      }

      function restoreOriginalList() {
        // Re-render the initial server output (no highlights).
        // innerHTML replacement detaches the previously cached nodes, so
        // immediately re-cache fresh references from the new DOM.
        list.innerHTML = originalItems.map(it => it.outerHTML).join('');
        const refreshed = list.querySelectorAll('.archive-item');
        for (let i = 0; i < originalItems.length; i++) {
          const el = refreshed[i];
          if (!el) continue;
          const it = originalItems[i];
          it.el = el;
          it.titleEl = el.querySelector('.archive-title');
          it.descEl = el.querySelector('.archive-desc');
          it.titleText = el.querySelector('.archive-title')?.textContent || '';
          it.descText = el.querySelector('.archive-desc')?.textContent || '';
        }
        clearHighlights();
      }

      function updateCount(visible) {
        if (!countEl) return;
        if (list.dataset.mode === 'search') {
          countEl.textContent = `Showing ${visible} of ${totalInCorpus}`;
        } else {
          countEl.textContent = `Showing ${visible} of ${originalItems.length}`;
        }
      }

      function updatePills() {
        tagButtons.forEach(btn => {
          const t = btn.dataset.tag || '';
          btn.classList.toggle('archive-tag-active', activeTags.has(t));
        });
        if (clearAll) clearAll.hidden = activeTags.size === 0 && (searchInput?.value || '').trim() === '';
      }

      function applyBrowseMode() {
        ensureOriginals();
        const qlow = query.toLowerCase();
        clearHighlights();
        let visible = 0;
        for (let i = 0; i < originalItems.length; i++) {
          const it = originalItems[i];
          const matchesSearch = !qlow || it.search.indexOf(qlow) !== -1;
          const matchesTag = activeTags.size === 0 || activeTags.has(it.cat);
          const show = matchesSearch && matchesTag;
          it.el.classList.toggle('archive-item-hidden', !show);
          if (show) {
            visible += 1;
            applyHighlights(it.el, query);
          }
        }
        setMode('browse');
        updateCount(visible);
        if (emptyState) emptyState.hidden = visible !== 0;
        updatePills();
        if (clearBtn) clearBtn.classList.toggle('is-visible', !!query.trim());
      }

      function applySearchMode() {
        const qlow = query.toLowerCase();
        const matches = corpus.filter(m => {
          const matchesSearch = !qlow || m.searchable.indexOf(qlow) !== -1;
          const matchesTag = activeTags.size === 0 || activeTags.has(m.catSlug);
          return matchesSearch && matchesTag;
        });
        renderSearchResults(matches, query);
        setMode('search');
        updateCount(matches.length);
        if (emptyState) emptyState.hidden = matches.length !== 0;
        updatePills();
        if (clearBtn) clearBtn.classList.toggle('is-visible', !!query.trim());
      }

      function hasFilters() {
        return (searchInput?.value || '').trim() !== '' || activeTags.size > 0;
      }

      function applyFilters() {
        if (hasFilters()) {
          if (list.dataset.mode !== 'search') {
            // Switching to full-corpus search.
            applySearchMode();
            return;
          }
          applySearchMode();
        } else if (list.dataset.mode === 'search') {
          // Returning to paginated browse.
          restoreOriginalList();
          applyBrowseMode();
        } else {
          applyBrowseMode();
        }
      }

      function readState() {
        const rawTags = (location.hash || '').replace(/^#tag-/, '').replace(/^#/, '');
        if (!rawTags) {
          activeTags = new Set();
        } else {
          activeTags = new Set(rawTags.split(',').map(normalizeTag).filter(Boolean));
        }
        if (searchInput) searchInput.value = query;
      }

      function writeUrlState() {
        let hash = '';
        if (activeTags.size > 0) hash = '#tag-' + Array.from(activeTags).join(',');
        history.replaceState(null, '', location.pathname + location.search + hash);
      }

      // ---------- Event wiring ----------

      let debounceTimer = 0;
      if (searchInput) {
        const onInput = () => {
          clearTimeout(debounceTimer);
          debounceTimer = window.setTimeout(() => {
            query = searchInput.value || '';
            if (query.trim() !== '') {
              // Persist as ?q= so users can share/bookmark.
              const url = new URL(location.href);
              url.searchParams.set('q', query);
              history.replaceState(null, '', url.pathname + url.search + location.hash);
            } else {
              const url = new URL(location.href);
              url.searchParams.delete('q');
              history.replaceState(null, '', url.pathname + url.search + location.hash);
            }
            applyFilters();
          }, 150);
        };
        searchInput.addEventListener('input', onInput);
      }

      if (clearBtn) {
        clearBtn.addEventListener('click', () => {
          if (searchInput) searchInput.value = '';
          query = '';
          applyFilters();
          if (searchInput) searchInput.focus();
        });
      }

      if (emptyReset) {
        emptyReset.addEventListener('click', () => {
          if (searchInput) searchInput.value = '';
          query = '';
          activeTags = new Set();
          writeUrlState();
          applyFilters();
          if (searchInput) searchInput.focus();
        });
      }

      if (clearAll) {
        clearAll.addEventListener('click', () => {
          if (searchInput) searchInput.value = '';
          query = '';
          activeTags = new Set();
          writeUrlState();
          applyFilters();
          if (searchInput) searchInput.focus();
        });
      }

      tagButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const t = btn.dataset.tag || '';
          if (!t) return;
          if (activeTags.has(t)) activeTags.delete(t);
          else activeTags.add(t);
          writeUrlState();
          applyFilters();
        });
      });

      window.addEventListener('hashchange', () => {
        readState();
        applyFilters();
      });

      // ---------- Initial state ----------
      // Load query from ?q=, then tags from #tag-...
      try {
        const params = new URLSearchParams(location.search);
        const qParam = params.get('q');
        if (qParam) query = qParam;
        const rawTags = (location.hash || '').replace(/^#tag-/, '').replace(/^#/, '');
        if (rawTags) {
          activeTags = new Set(rawTags.split(',').map(normalizeTag).filter(Boolean));
        }
        if (searchInput) searchInput.value = query;
      } catch (e) { /* ignore */ }

      ensureOriginals();
      applyFilters();
    });
  })();
</script>

<style>
  .blog-index-page { padding-top: var(--header-height); }

  /* ---------- Page header / hero ---------- */
  .page-header {
    padding: 6rem 0 3rem;
    text-align: center;
    position: relative;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 60%;
    max-width: 900px;
    height: 60%;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse at center, rgba(139, 92, 246, 0.12) 0%, rgba(20, 184, 166, 0.05) 40%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .page-header > .container { position: relative; z-index: 1; }

  .section-eyebrow {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    color: var(--accent-light);
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border: 1px solid rgba(139, 92, 246, 0.3);
    background: rgba(139, 92, 246, 0.08);
    border-radius: var(--radius-full);
    margin-bottom: 1rem;
  }
  .page-header h1 {
    font-size: clamp(2.4rem, 5.5vw, 3.8rem);
    margin-bottom: 0.85rem;
