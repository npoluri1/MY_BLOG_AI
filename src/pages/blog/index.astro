---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const years = [...new Set(posts.map(p => p.data.pubDate.getFullYear()))].sort((a, b) => b - a);
const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
---

<BaseLayout title="Blog | Naga Siva Poluri" description="Thoughts on AI, enterprise engineering, and building intelligent systems.">
  <div class="blog-index-page">
    <div class="page-header">
      <div class="container">
        <h1>My Blog</h1>
        <p class="subtitle">Reflections on AI, enterprise engineering, and building intelligent systems.</p>
      </div>
    </div>

    <div class="container blog-list-container">
      <div id="archiveData" data-archive={JSON.stringify(years.map(y => ({ year: y, months: [...new Set(posts.filter(p => p.data.pubDate.getFullYear() === y).map(p => p.data.pubDate.getMonth()))] })))} style="display: none;"></div>

      <div class="calendar-filter-wrapper">
        <div class="calendar-filter-container">
          <span class="calendar-label">Filter by Date:</span>
          <div class="date-selectors">
            <div class="select-wrapper">
              <select id="yearFilter" class="filter-select" aria-label="Filter by Year">
                <option value="all">All Years</option>
                {years.map(y => <option value={y}>{y}</option>)}
              </select>
            </div>
            <div class="select-wrapper">
              <select id="monthFilter" class="filter-select" disabled aria-label="Filter by Month">
                <option value="all">All Months</option>
                {months.map((m, i) => <option value={i}>{m}</option>)}
              </select>
            </div>
          </div>
        </div>
      </div>

      <div class="filter-status" id="filterStatus" style="display: none;">
        <span class="filter-text">Active Filters:</span>
        <div id="activeFiltersList" class="active-filters-list"></div>
        <button id="clearFilterBtn" class="clear-all-btn">Clear All</button>
      </div>

      <div class="pagination-container pagination-top" id="paginationContainerTop" style="display: none;">
        <button id="prevPageBtnTop" class="pagination-btn" aria-label="Previous Page">&larr; Previous</button>
        <div id="pageNumbersContainerTop" class="page-numbers"></div>
        <button id="nextPageBtnTop" class="pagination-btn" aria-label="Next Page">Next &rarr;</button>
      </div>

      <div class="blog-grid" id="blogGrid">
        {posts.map(post => (
          <article
            class="card blog-list-card"
            data-tags={(post.data.category || post.data.tags || []).join(',')}
            data-date={post.data.pubDate.toISOString()}
          >
            <div class="card-thumbnail">
              <a href={`/blog/${post.id}`}>
                {post.data.heroImage ? (
                  <img src={post.data.heroImage} alt={post.data.title} loading="lazy" decoding="async" width="1200" height="675" class="thumbnail-img" />
                ) : (
                  <img src={`https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&h=400&fit=crop`} alt={post.data.title} loading="lazy" decoding="async" width="600" height="400" class="thumbnail-img" />
                )}
              </a>
            </div>
            <div class="card-content">
              <div class="card-meta">
                <span class="card-date">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                <div class="card-badges">
                  {(post.data.category || post.data.tags || []).slice(0, 4).map(tag => (
                    <button class="card-badge tag-button" data-tag={tag}>{tag}</button>
                  ))}
                </div>
              </div>
              <h2>
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h2>
              <p class="card-description">{post.data.description}</p>
              <div class="card-footer">
                <a href={`/blog/${post.id}`} class="read-more">Read Article &rarr;</a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="no-results" id="noResults" style="display: none;">
        <p>No posts found matching your filters.</p>
      </div>

      <div class="pagination-container pagination-bottom" id="paginationContainerBottom" style="display: none;">
        <button id="prevPageBtnBottom" class="pagination-btn" aria-label="Previous Page">&larr; Previous</button>
        <div id="pageNumbersContainerBottom" class="page-numbers"></div>
        <button id="nextPageBtnBottom" class="pagination-btn" aria-label="Next Page">Next &rarr;</button>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .blog-index-page {
    padding-top: var(--header-height);
  }

  .page-header {
    padding: 4rem 0 3rem;
    text-align: center;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: 0.75rem;
  }

  .subtitle {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .blog-list-container {
    padding: 0 0 6rem;
  }

  .calendar-filter-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .calendar-filter-container {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .calendar-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .date-selectors {
    display: flex;
    gap: 0.5rem;
  }

  .select-wrapper select {
    padding: 0.5rem 1rem;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    cursor: pointer;
    outline: none;
    transition: border-color 0.2s;
  }

  .select-wrapper select:focus {
    border-color: var(--accent);
  }

  .select-wrapper select:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .filter-status {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding: 0.75rem 1rem;
    background: rgba(139, 92, 246, 0.05);
    border: 1px solid rgba(139, 92, 246, 0.15);
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    flex-wrap: wrap;
  }

  .filter-text {
    color: var(--text-muted);
    font-weight: 600;
  }

  .active-filters-list {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .active-filters-list .filter-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.6rem;
    background: rgba(139, 92, 246, 0.15);
    border-radius: var(--radius-sm);
    color: var(--accent-light);
    font-size: 0.78rem;
  }

  .active-filters-list .filter-tag .remove-tag {
    cursor: pointer;
    opacity: 0.7;
    font-size: 0.9rem;
    line-height: 1;
  }

  .active-filters-list .filter-tag .remove-tag:hover {
    opacity: 1;
  }

  .clear-all-btn {
    padding: 0.3rem 0.75rem;
    background: rgba(139, 92, 246, 0.15);
    border: 1px solid rgba(139, 92, 246, 0.3);
    border-radius: var(--radius-sm);
    color: var(--accent-light);
    font-size: 0.8rem;
    cursor: pointer;
    font-family: var(--font-sans);
  }

  .clear-all-btn:hover {
    background: rgba(139, 92, 246, 0.25);
  }

  .blog-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .blog-list-card {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .blog-list-card:hover {
    padding-left: 0.5rem;
  }

  .blog-list-card:hover .thumbnail-img {
    transform: scale(1.03);
  }

  .card-thumbnail {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-md);
    aspect-ratio: 16 / 9;
  }

  .card-thumbnail a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .thumbnail-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .card-date {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .card-badges {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .card-badge {
    display: inline-block;
    padding: 0.15rem 0.55rem;
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: var(--radius-sm);
    color: var(--accent-light);
    font-size: 0.72rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-sans);
  }

  .card-badge:hover {
    background: rgba(139, 92, 246, 0.2);
    border-color: rgba(139, 92, 246, 0.4);
  }

  .card-content h2 {
    font-size: 1.15rem;
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }

  .card-content h2 a {
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .card-content h2 a:hover {
    color: var(--accent-light);
  }

  .card-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .card-footer {
    margin-top: auto;
  }

  .read-more {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-light);
    text-decoration: none;
    transition: color 0.2s;
  }

  .read-more:hover {
    color: var(--teal-light);
  }

  .no-results {
    text-align: center;
    padding: 4rem 0;
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  .pagination-container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .pagination-btn {
    padding: 0.5rem 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .pagination-btn:hover:not(:disabled) {
    background: rgba(139, 92, 246, 0.15);
    border-color: var(--accent);
    color: var(--accent-light);
  }

  .pagination-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .page-numbers {
    display: flex;
    gap: 0.25rem;
  }

  .page-numbers button {
    min-width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .page-numbers button:hover:not(.active) {
    background: rgba(139, 92, 246, 0.15);
    border-color: var(--accent);
    color: var(--accent-light);
  }

  .page-numbers button.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  @media (max-width: 768px) {
    .blog-list-card {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .card-thumbnail {
      aspect-ratio: 16 / 9;
    }

    .calendar-filter-container {
      flex-direction: column;
      align-items: flex-start;
    }

    .pagination-container {
      flex-wrap: wrap;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const POSTS_PER_PAGE = 10;
    let currentPage = 1;
    let filteredCards = [];

    const blogGrid = document.getElementById('blogGrid');
    const noResults = document.getElementById('noResults');
    const yearFilter = document.getElementById('yearFilter');
    const monthFilter = document.getElementById('monthFilter');
    const clearFilterBtn = document.getElementById('clearFilterBtn');
    const filterStatus = document.getElementById('filterStatus');
    const activeFiltersList = document.getElementById('activeFiltersList');

    const allCards = Array.from(blogGrid.querySelectorAll('.blog-list-card'));

    const archiveData = JSON.parse(document.getElementById('archiveData').dataset.archive || '[]');

    yearFilter.addEventListener('change', () => {
      const selectedYear = yearFilter.value;
      monthFilter.disabled = selectedYear === 'all';
      if (selectedYear !== 'all') {
        const yearData = archiveData.find(d => d.year === parseInt(selectedYear));
        const availableMonths = yearData ? yearData.months : [];
        Array.from(monthFilter.options).forEach(opt => {
          if (opt.value === 'all') return;
          opt.disabled = !availableMonths.includes(parseInt(opt.value));
        });
      } else {
        Array.from(monthFilter.options).forEach(opt => opt.disabled = false);
      }
      monthFilter.value = 'all';
      applyFilters();
    });

    monthFilter.addEventListener('change', applyFilters);

    clearFilterBtn.addEventListener('click', () => {
      yearFilter.value = 'all';
      monthFilter.value = 'all';
      monthFilter.disabled = true;
      applyFilters();
    });

    document.addEventListener('click', (e) => {
      if (e.target.classList.contains('tag-button')) {
        const tag = e.target.dataset.tag;
        filterByTag(tag);
      }
      if (e.target.classList.contains('remove-tag')) {
        clearAllTagFilters();
      }
    });

    function filterByTag(tag) {
      allCards.forEach(card => {
        const tags = card.dataset.tags.split(',').map(t => t.trim().toLowerCase());
        card.style.display = tags.includes(tag.toLowerCase()) ? '' : 'none';
      });
      showActiveTagFilter(tag);
      currentPage = 1;
      paginateCards();
    }

    function showActiveTagFilter(tag) {
      filterStatus.style.display = 'flex';
      activeFiltersList.innerHTML = `<span class="filter-tag">${tag} <span class="remove-tag">&times;</span></span>`;
    }

    function clearAllTagFilters() {
      allCards.forEach(card => card.style.display = '');
      filterStatus.style.display = 'none';
      activeFiltersList.innerHTML = '';
      currentPage = 1;
      paginateCards();
    }

    function applyFilters() {
      const selectedYear = yearFilter.value;
      const selectedMonth = monthFilter.value;

      allCards.forEach(card => {
        const date = new Date(card.dataset.date);
        const matchYear = selectedYear === 'all' || date.getFullYear() === parseInt(selectedYear);
        const matchMonth = selectedMonth === 'all' || date.getMonth() === parseInt(selectedMonth);
        card.style.display = (matchYear && matchMonth) ? '' : 'none';
      });

      filterStatus.style.display = (selectedYear !== 'all' || selectedMonth !== 'all') ? 'flex' : 'none';
      if (selectedYear !== 'all' || selectedMonth !== 'all') {
        const filters = [];
        if (selectedYear !== 'all') filters.push(selectedYear);
        if (selectedMonth !== 'all') filters.push(monthFilter.options[monthFilter.selectedIndex].text);
        activeFiltersList.innerHTML = `<span class="filter-tag">${filters.join(' / ')} <span class="remove-tag">&times;</span></span>`;
      }

      currentPage = 1;
      paginateCards();
    }

    function paginateCards() {
      filteredCards = allCards.filter(card => card.style.display !== 'none');
      const totalPages = Math.ceil(filteredCards.length / POSTS_PER_PAGE);

      if (currentPage > totalPages) currentPage = Math.max(1, totalPages);

      filteredCards.forEach((card, index) => {
        const start = (currentPage - 1) * POSTS_PER_PAGE;
        const end = start + POSTS_PER_PAGE;
        card.style.display = (index >= start && index < end) ? '' : 'none';
      });

      noResults.style.display = filteredCards.length === 0 ? 'block' : 'none';

      const showPagination = totalPages > 1;
      document.getElementById('paginationContainerTop').style.display = showPagination ? 'flex' : 'none';
      document.getElementById('paginationContainerBottom').style.display = showPagination ? 'flex' : 'none';

      if (!showPagination) return;

      renderPaginationControls('pageNumbersContainerTop', 'prevPageBtnTop', 'nextPageBtnTop', currentPage, totalPages);
      renderPaginationControls('pageNumbersContainerBottom', 'prevPageBtnBottom', 'nextPageBtnBottom', currentPage, totalPages);
    }

    function renderPaginationControls(numbersId, prevId, nextId, current, total) {
      const container = document.getElementById(numbersId);
      const prevBtn = document.getElementById(prevId);
      const nextBtn = document.getElementById(nextId);

      prevBtn.disabled = current === 1;
      nextBtn.disabled = current === total;

      let html = '';
      for (let i = 1; i <= total; i++) {
        if (i === 1 || i === total || (i >= current - 2 && i <= current + 2)) {
          html += `<button class="${i === current ? 'active' : ''}" data-page="${i}">${i}</button>`;
        } else if (i === current - 3 || i === current + 3) {
          html += '<span style="color: var(--text-muted); padding: 0 0.25rem;">...</span>';
        }
      }
      container.innerHTML = html;

      container.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', () => {
          const page = parseInt(btn.dataset.page);
          if (page && page !== current) {
            currentPage = page;
            paginateCards();
            window.scrollTo({ top: blogGrid.offsetTop - 100, behavior: 'smooth' });
          }
        });
      });

      prevBtn.onclick = () => {
        if (currentPage > 1) {
          currentPage--;
          paginateCards();
          window.scrollTo({ top: blogGrid.offsetTop - 100, behavior: 'smooth' });
        }
      };

      nextBtn.onclick = () => {
        if (currentPage < total) {
          currentPage++;
          paginateCards();
          window.scrollTo({ top: blogGrid.offsetTop - 100, behavior: 'smooth' });
        }
      };
    }

    paginateCards();
  });
</script>
