---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ThreeConstellation from '../../components/ThreeConstellation.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const constellationPosts = allPosts.map(p => ({
  slug: p.id.replace(/\.md$/, ''),
  title: p.data.title,
  tags: p.data.tags || p.data.category || [],
  primaryCategory: p.data.primaryCategory || (p.data.tags && p.data.tags[0]) || (p.data.category && p.data.category[0]) || 'uncategorized',
  pubDate: p.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
}));

const totalCount = allPosts.length;
const tagCounts = {};
for (const p of allPosts) {
  const t = p.data.primaryCategory || (p.data.tags && p.data.tags[0]) || (p.data.category && p.data.category[0]) || 'uncategorized';
  tagCounts[t] = (tagCounts[t] || 0) + 1;
}
const topTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]).slice(0, 8);

// Flatten post data for client-side filtering (search + tag). Each item exposes a `data-*` corpus
// the JS handler uses for fast text matching and category-based filtering without innerHTML.
function excerptSearchable(post) {
  const t = (post.data.title || '').toLowerCase();
  const d = (post.data.description || '').toLowerCase();
  const c = (post.data.primaryCategory || '').toLowerCase();
  const tags = (post.data.tags || []).join(' ').toLowerCase();
  return t + ' ' + d + ' ' + c + ' ' + tags;
}

const archiveItems = allPosts.map(post => ({
  slug: post.id.replace(/\.md$/, ''),
  title: post.data.title,
  description: post.data.description || '',
  pubDateIso: post.data.pubDate.toISOString(),
  pubDateLabel: post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }),
  primaryCategory: post.data.primaryCategory || (post.data.tags && post.data.tags[0]) || (post.data.category && post.data.category[0]) || 'Essay',
  searchable: excerptSearchable(post),
}));
---

<BaseLayout title="Constellation | Naga Siva Poluri Archive" description="An unconventional 3D universe of writings on AI, agentic systems, agile, and the engineering mind — curated by Naga Siva Poluri.">
  <div class="blog-index-page">
    <div class="page-header">
      <div class="container">
        <span class="section-eyebrow reveal">THE EMPTYING THE CUP ARCHIVE</span>
        <h1 class="reveal stagger-1">A Constellation of Ideas</h1>
        <p class="subtitle reveal stagger-2">
          {totalCount} essays on AI, agentic systems, agile, governance, and the engineer's evolution — curated by Naga Siva Poluri
          and arranged as a navigable 3D universe.
        </p>
      </div>
    </div>

    <section class="constellation-wrap reveal stagger-3">
      <div class="container container-wide">
        <ThreeConstellation posts={constellationPosts} />
      </div>
    </section>

    <section class="archive-section">
      <div class="container">
        <div class="archive-header">
          <h2>The Written Archive</h2>
          <p>Prefer the classic list view? Browse every post chronologically below.</p>
        </div>

        <div class="archive-search-row">
          <div class="archive-search-input-wrap">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="archiveSearch" type="search" placeholder="Search {totalCount}+ articles by title or topic..." autocomplete="off" aria-label="Search articles" />
            <button id="archiveSearchClear" class="archive-search-clear" type="button" aria-label="Clear search">x</button>
          </div>
          <div class="archive-result-count" id="archiveResultCount">{totalCount} articles</div>
        </div>

        <div class="archive-tag-row">
          {topTags.map(([t, c]) => (
            <a href={`#tag-${t.replace(/\s+/g, '-')}`} class="archive-tag">
              <span class="archive-tag-name">{t}</span>
              <span class="archive-tag-count">{c}</span>
            </a>
          ))}
        </div>

        <ol class="archive-list">
          {archiveItems.map(item => (
            <li class="archive-item" data-archive-item data-cat={item.primaryCategory.toLowerCase().replace(/\s+/g, '-')} data-search={item.searchable}>
              <a href={`/blog/${item.slug}`} class="archive-link">
                <div class="archive-meta">
                  <time datetime={item.pubDateIso}>{item.pubDateLabel}</time>
                  <span class="archive-cat">{item.primaryCategory}</span>
                </div>
                <h3 class="archive-title">{item.title}</h3>
                <p class="archive-desc">{item.description}</p>
                <span class="archive-arrow">Read →</span>
              </a>
            </li>
          ))}
        </ol>

        <div id="archiveEmptyState" class="archive-empty-state" hidden>
          <p>No articles match the current filters.</p>
          <button type="button" id="archiveEmptyReset" class="archive-empty-reset">Reset filters</button>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script is:inline>
  // Archive list filtering (text search + tag pill filter, AND-combined).
  // Strategy: cache original text once, filter visibility classes, XSS-safe highlighting via DOM API only.
  (function () {
    if (typeof document === 'undefined') return;

    function ready(fn) {
      if (document.readyState !== 'loading') fn();
      else document.addEventListener('DOMContentLoaded', fn);
    }

    ready(function () {
      const items = Array.from(document.querySelectorAll('[data-archive-item]'));
      const searchInput = document.getElementById('archiveSearch');
      const clearBtn = document.getElementById('archiveSearchClear');
      const countEl = document.getElementById('archiveResultCount');
      const emptyState = document.getElementById('archiveEmptyState');
      const emptyReset = document.getElementById('archiveEmptyReset');
      const total = items.length;

      if (!items.length) return;

      // Cache original text + searchable corpus.
      const cache = items.map(function (li) {
        const titleEl = li.querySelector('.archive-title');
        const descEl = li.querySelector('.archive-desc');
        const cat = (li.dataset.cat || '').toLowerCase();
        const search = li.dataset.search || '';
        return {
          el: li,
          titleEl: titleEl,
          descEl: descEl,
          cat: cat,
          titleText: titleEl ? titleEl.textContent : '',
          descText: descEl ? descEl.textContent : '',
          search: search,
        };
      });

      let query = '';
      let activeTags = new Set();

      function normalizeTag(t) {
        return (t || '').toLowerCase().replace(/\s+/g, '-');
      }

      function resetHighlight(el, original) {
        if (el) el.textContent = original;
      }

      function highlight(el, original, q) {
        if (!el) return;
        if (!q) { el.textContent = original; return; }
        el.textContent = '';
        const lower = original.toLowerCase();
        const ql = q.toLowerCase();
        let last = 0;
        let idx = lower.indexOf(ql, last);
        while (idx !== -1) {
          if (idx > last) el.appendChild(document.createTextNode(original.slice(last, idx)));
          const mark = document.createElement('mark');
          mark.className = 'archive-mark';
          mark.textContent = original.slice(idx, idx + q.length);
          el.appendChild(mark);
          last = idx + q.length;
          idx = lower.indexOf(ql, last);
        }
        if (last < original.length) el.appendChild(document.createTextNode(original.slice(last)));
      }

      function applyFilters() {
        const qlow = query.toLowerCase();
        let visible = 0;
        for (let i = 0; i < cache.length; i++) {
          const d = cache[i];
          const matchesSearch = !qlow || d.search.indexOf(qlow) !== -1;
          const matchesTag = activeTags.size === 0 || activeTags.has(d.cat);
          const show = matchesSearch && matchesTag;
          d.el.classList.toggle('archive-item-hidden', !show);
          if (show) {
            visible += 1;
            highlight(d.titleEl, d.titleText, query);
            highlight(d.descEl, d.descText, query);
          } else {
            resetHighlight(d.titleEl, d.titleText);
            resetHighlight(d.descEl, d.descText);
          }
        }
        if (countEl) {
          countEl.textContent = visible + ' of ' + total + ' article' + (total === 1 ? '' : 's');
        }
        if (emptyState) emptyState.hidden = visible !== 0;
        if (clearBtn) clearBtn.classList.toggle('hidden', !query);

        const pills = document.querySelectorAll('.archive-tag');
        pills.forEach(function (p) {
          const href = p.getAttribute('href') || '';
          const m = href.replace('#tag-', '').toLowerCase();
          p.classList.toggle('archive-tag-active', activeTags.has(m));
        });
      }

      function readHash() {
        const raw = (location.hash || '').replace(/^#tag-/, '');
        if (!raw || raw === 'clear' || raw === 'all') return new Set();
        return new Set(raw.split(',').map(normalizeTag).filter(Boolean));
      }

      function writeHash() {
        let h = '';
        if (activeTags.size > 0) h = '#tag-' + Array.from(activeTags).join(',');
        history.replaceState(null, '', h || location.pathname + location.search);
      }

      let debounceTimer = 0;
      if (searchInput) {
        searchInput.addEventListener('input', function (e) {
          const value = e.target.value || '';
          clearTimeout(debounceTimer);
          debounceTimer = window.setTimeout(function () {
            query = value;
            applyFilters();
          }, 150);
        });
      }

      if (clearBtn) {
        clearBtn.addEventListener('click', function () {
          if (searchInput) searchInput.value = '';
          query = '';
          applyFilters();
          if (searchInput) searchInput.focus();
        });
      }

      if (emptyReset) {
        emptyReset.addEventListener('click', function () {
          if (searchInput) searchInput.value = '';
          query = '';
          activeTags = new Set();
          writeHash();
          applyFilters();
          if (searchInput) searchInput.focus();
        });
      }

      // Tag pill click => toggle membership, then pushState so hashchange-firing browser handlers don't double-fire.
      const pills = document.querySelectorAll('.archive-tag');
      pills.forEach(function (p) {
        p.addEventListener('click', function (e) {
          e.preventDefault();
          const href = p.getAttribute('href') || '';
          const t = normalizeTag(href.replace('#tag-', ''));
          if (!t) return;
          if (activeTags.has(t)) activeTags.delete(t);
          else activeTags.add(t);
          writeHash();
          applyFilters();
        });
      });

      // hashchange handles deep-link entry + browser back / forward for tag-only state.
      window.addEventListener('hashchange', function () {
        activeTags = readHash();
        applyFilters();
      });

      // Initial fetch of state from URL on page load.
      activeTags = readHash();
      applyFilters();
    });
  })();
</script>

<style>
  .blog-index-page { padding-top: var(--header-height); }

  .page-header {
    padding: 6rem 0 2rem;
    text-align: center;
  }
  .page-header h1 {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }
  .subtitle {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .container-wide {
    max-width: 1320px;
  }

  .constellation-wrap {
    padding: 1rem 0 3rem;
  }

  .archive-section {
    padding: 3rem 0 6rem;
    border-top: 1px solid var(--border);
  }
  .archive-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .archive-header h2 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    margin-bottom: 0.4rem;
  }
  .archive-header p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .archive-search-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin: 0 auto 1.5rem;
    max-width: 640px;
    flex-wrap: wrap;
  }
  .archive-search-input-wrap {
    position: relative;
    flex: 1 1 320px;
    display: flex;
    align-items: center;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    padding: 0.4rem 0.4rem 0.4rem 0.95rem;
    transition: var(--transition-fast);
  }
  .archive-search-input-wrap:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.12);
  }
  .archive-search-input-wrap svg { color: var(--text-muted); flex-shrink: 0; }
  .archive-search-input-wrap input {
    flex: 1;
    background: none;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    padding: 0.5rem 0.75rem;
    outline: none;
    min-width: 0;
  }
  .archive-search-input-wrap input::placeholder { color: var(--text-muted); }
  .archive-search-clear {
    background: none;
    border: none;
    color: var(--text-muted);
    width: 28px;
    height: 28px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1rem;
    transition: var(--transition-fast);
  }
  .archive-search-clear:hover { background: rgba(255,255,255,0.08); color: var(--accent-light); }
  .archive-search-clear.hidden { display: none; }
  .archive-result-count {
    font-family: var(--font-display);
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  .archive-tag-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }
  .archive-list .archive-item-hidden { display: none; }
  .archive-list mark.archive-mark {
    background: rgba(139, 92, 246, 0.18);
    color: var(--accent-light);
    padding: 0 0.15rem;
    border-radius: 0.15rem;
  }
  .archive-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem 0.85rem;
    background: rgba(139, 92, 246, 0.06);
    border: 1px solid rgba(139, 92, 246, 0.18);
    border-radius: var(--radius-full);
    color: var(--text-secondary);
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: var(--transition-fast);
  }
  .archive-tag:hover {
    border-color: var(--accent);
    background: rgba(139, 92, 246, 0.14);
    color: var(--accent-light);
  }
  .archive-tag-count {
    font-size: 0.65rem;
    background: rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-full);
    padding: 0.05rem 0.45rem;
    color: var(--text-muted);
  }

  .archive-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  .archive-item {
    border-bottom: 1px solid var(--border);
  }
  .archive-link {
    display: grid;
    grid-template-columns: 200px 1fr auto;
    gap: 1.5rem;
    align-items: center;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding-left 0.3s var(--ease-out);
  }
  .archive-link:hover {
    padding-left: 0.5rem;
  }
  .archive-meta {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-size: 0.78rem;
  }
  .archive-meta time { color: var(--accent-light); font-weight: 600; }
  .archive-cat {
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.7rem;
  }
  .archive-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.35;
    transition: color 0.2s;
  }
  .archive-link:hover .archive-title { color: var(--accent-light); }
  .archive-desc {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-top: 0.3rem;
  }
  .archive-arrow {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-light);
    opacity: 0.5;
    transition: var(--transition-fast);
  }
  .archive-link:hover .archive-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  .archive-empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-muted);
  }
  .archive-empty-state p { margin-bottom: 1rem; }
  .archive-empty-reset {
    background: var(--accent);
    color: white;
    border: none;
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-full);
    font-family: var(--font-display);
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition-fast);
  }
  .archive-empty-reset:hover {
    background: var(--accent-light);
    transform: translateY(-1px);
  }
  .archive-tag-active {
    background: rgba(139, 92, 246, 0.18) !important;
    border-color: var(--accent) !important;
    color: var(--accent-light) !important;
  }

  @media (max-width: 768px) {
    .archive-link {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
    .archive-arrow { display: none; }
  }
</style>
