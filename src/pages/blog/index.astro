---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const years = [...new Set(posts.map(p => p.data.pubDate.getFullYear()))].sort((a, b) => b - a);
const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

// Calculate reading time for each post
function getReadingTime(content: string): number {
  const wordCount = content.split(/\s+/).length;
  return Math.max(1, Math.ceil(wordCount / 200));
}
---

<BaseLayout title="Blog | Naga Siva Poluri" description="Thoughts on AI, enterprise engineering, and building intelligent systems.">
  <div class="page-header">
    <div class="container">
      <h1>My Blog</h1>
      <p class="subtitle">Reflections on AI, enterprise engineering, and building intelligent systems.</p>
    </div>
  </div>

  <section class="blog-section">
    <div class="container">
      <div class="blog-controls">
        <div class="filter-group">
          <label>Filter by Date:</label>
          <div class="filter-selects">
            <select id="year-filter">
              <option value="all">All Years</option>
              {years.map(y => <option value={y}>{y}</option>)}
            </select>
            <select id="month-filter">
              <option value="all">All Months</option>
              {months.map((m, i) => <option value={i}>{m}</option>)}
            </select>
          </div>
        </div>
        <div class="active-filters" id="active-filters" style="display:none;">
          <span>Active Filters:</span>
          <button id="clear-filters">Clear All</button>
        </div>
      </div>

      <div class="posts-list" id="posts-list">
        {posts.map(post => (
          <a
            href={`/blog/${post.id}`}
            class="post-card"
            data-year={post.data.pubDate.getFullYear()}
            data-month={post.data.pubDate.getMonth()}
            data-tags={(post.data.category || post.data.tags || []).join(',')}
            data-title={post.data.title.toLowerCase()}
          >
            <div class="post-image-wrapper">
              {(post.data.image || post.data.heroImage) && (
                <img src={post.data.image || post.data.heroImage} alt={post.data.title} class="post-image" loading="lazy" />
              )}
            </div>
            <div class="post-content">
              <div class="post-meta">
                <span class="post-date">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                <span class="reading-time">{getReadingTime(post.body || '')} min read</span>
              </div>
              <div class="post-tags">
                {(post.data.category || post.data.tags || []).slice(0, 3).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              <span class="post-link">Read Article →</span>
            </div>
          </a>
        ))}
      </div>

      <div class="no-results" id="no-results" style="display:none;">
        <p>No posts found matching your filters.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 8rem 0 3rem;
    text-align: center;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: 0.75rem;
  }

  .subtitle {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .blog-section { padding: 2rem 0 6rem; }

  .blog-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .filter-group label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .filter-selects {
    display: flex;
    gap: 0.5rem;
  }

  .filter-selects select {
    padding: 0.5rem 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    cursor: pointer;
    outline: none;
  }

  .filter-selects select:focus {
    border-color: var(--accent);
  }

  .active-filters {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  #clear-filters {
    padding: 0.3rem 0.75rem;
    background: rgba(139, 92, 246, 0.15);
    border: 1px solid rgba(139, 92, 246, 0.3);
    border-radius: var(--radius-sm);
    color: var(--accent-light);
    font-size: 0.8rem;
    cursor: pointer;
    font-family: var(--font-sans);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
  }

  .post-card {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: var(--transition-fast);
  }

  .post-card:hover {
    padding-left: 0.5rem;
  }

  .post-image-wrapper {
    width: 200px;
    height: 130px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    flex-shrink: 0;
  }

  .post-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
  }

  .post-date {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .reading-time {
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    background: rgba(139, 92, 246, 0.1);
    border-radius: var(--radius-full);
    color: var(--accent-light);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.5rem;
  }

  .tag {
    font-size: 0.72rem;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    background: rgba(139, 92, 246, 0.1);
    color: var(--accent-light);
    font-weight: 500;
  }

  .post-title {
    font-size: 1.1rem;
    margin-bottom: 0.4rem;
    line-height: 1.4;
    color: var(--text-primary);
  }

  .post-card:hover .post-title {
    color: var(--accent-light);
  }

  .post-desc {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .post-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-light);
  }

  .no-results {
    text-align: center;
    padding: 4rem 0;
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .post-card { grid-template-columns: 1fr; }
    .post-image-wrapper { width: 100%; height: 180px; }
    .blog-controls { flex-direction: column; align-items: flex-start; }
    .filter-group { flex-direction: column; align-items: flex-start; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const yearFilter = document.getElementById('year-filter');
    const monthFilter = document.getElementById('month-filter');
    const clearBtn = document.getElementById('clear-filters');
    const activeFilters = document.getElementById('active-filters');
    const postsList = document.getElementById('posts-list');
    const noResults = document.getElementById('no-results');

    function filterPosts() {
      const year = yearFilter.value;
      const month = monthFilter.value;
      const items = postsList.querySelectorAll('.post-card');
      let visibleCount = 0;

      items.forEach(item => {
        const matchYear = year === 'all' || item.dataset.year === year;
        const matchMonth = month === 'all' || item.dataset.month === month;

        if (matchYear && matchMonth) {
          item.style.display = '';
          visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });

      const hasFilters = year !== 'all' || month !== 'all';
      activeFilters.style.display = hasFilters ? 'flex' : 'none';
      noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    }

    yearFilter.addEventListener('change', filterPosts);
    monthFilter.addEventListener('change', filterPosts);
    clearBtn.addEventListener('click', () => {
      yearFilter.value = 'all';
      monthFilter.value = 'all';
      filterPosts();
    });
  });
</script>
