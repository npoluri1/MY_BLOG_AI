---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const years = [...new Set(posts.map(p => p.data.pubDate.getFullYear()))].sort((a, b) => b - a);
const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
---

<BaseLayout title="Blog | Naga Siva Poluri" description="Thoughts on AI, enterprise engineering, and building intelligent systems.">
  <div class="page-header">
    <div class="container">
      <h1>My Blog</h1>
      <p class="subtitle">Reflections on software engineering, pipeline automation, graphics, and system reliability.</p>
    </div>
  </div>

  <section class="blog-section">
    <div class="container">
      <div class="blog-controls">
        <div class="filter-group">
          <label>Filter by Date:</label>
          <div class="filter-selects">
            <select id="year-filter">
              <option value="all">All Years</option>
              {years.map(y => <option value={y}>{y}</option>)}
            </select>
            <select id="month-filter">
              <option value="all">All Months</option>
              {months.map((m, i) => <option value={i}>{m}</option>)}
            </select>
          </div>
        </div>
        <div class="active-filters" id="active-filters" style="display:none;">
          <span>Active Filters:</span>
          <button id="clear-filters">Clear All</button>
        </div>
      </div>

      <div class="posts-list" id="posts-list">
        {posts.map(post => (
          <a
            href={`/blog/${post.id}`}
            class="post-card"
            data-year={post.data.pubDate.getFullYear()}
            data-month={post.data.pubDate.getMonth()}
            data-tags={(post.data.category || post.data.tags || []).join(',')}
            data-title={post.data.title.toLowerCase()}
          >
            <div class="post-content">
              <div class="post-meta">
                <span class="post-date">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              </div>
              <div class="post-tags">
                {(post.data.category || post.data.tags || []).slice(0, 3).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              <span class="post-link">Read Article →</span>
            </div>
          </a>
        ))}
      </div>

      <div class="no-results" id="no-results" style="display:none;">
        <p>No posts found matching your filters.</p>
      </div>

      <!-- Pagination -->
      <div class="pagination" id="pagination"></div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 8rem 0 3rem;
    text-align: center;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: 0.75rem;
  }

  .subtitle {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .blog-section { padding: 2rem 0 6rem; }

  .blog-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .filter-group label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .filter-selects {
    display: flex;
    gap: 0.5rem;
  }

  .filter-selects select {
    padding: 0.5rem 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    cursor: pointer;
    outline: none;
  }

  .filter-selects select:focus {
    border-color: var(--accent);
  }

  .active-filters {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  #clear-filters {
    padding: 0.3rem 0.75rem;
    background: rgba(139, 92, 246, 0.15);
    border: 1px solid rgba(139, 92, 246, 0.3);
    border-radius: var(--radius-sm);
    color: var(--accent-light);
    font-size: 0.8rem;
    cursor: pointer;
    font-family: var(--font-sans);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
  }

  .post-card {
    display: block;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: var(--transition-fast);
  }

  .post-card:hover {
    padding-left: 0.5rem;
  }

  .post-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
  }

  .post-date {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.5rem;
  }

  .tag {
    font-size: 0.72rem;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    background: rgba(139, 92, 246, 0.1);
    color: var(--accent-light);
    font-weight: 500;
  }

  .post-title {
    font-size: 1.1rem;
    margin-bottom: 0.4rem;
    line-height: 1.4;
    color: var(--text-primary);
  }

  .post-card:hover .post-title {
    color: var(--accent-light);
  }

  .post-desc {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .post-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-light);
  }

  .no-results {
    text-align: center;
    padding: 4rem 0;
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  /* Pagination */
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .pagination button {
    padding: 0.5rem 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    cursor: pointer;
    transition: var(--transition-fast);
  }

  .pagination button:hover:not(:disabled) {
    background: rgba(139, 92, 246, 0.15);
    border-color: var(--border-accent);
    color: var(--accent-light);
  }

  .pagination button:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .pagination button.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  .pagination .page-numbers {
    display: flex;
    gap: 0.25rem;
  }

  .pagination .page-btn {
    min-width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .pagination .nav-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  @media (max-width: 768px) {
    .blog-controls { flex-direction: column; align-items: flex-start; }
    .filter-group { flex-direction: column; align-items: flex-start; }
    .pagination { flex-wrap: wrap; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const POSTS_PER_PAGE = 10;
    let currentPage = 1;
    let filteredPosts = [];

    const postsList = document.getElementById('posts-list');
    const noResults = document.getElementById('no-results');
    const pagination = document.getElementById('pagination');
    const yearFilter = document.getElementById('year-filter');
    const monthFilter = document.getElementById('month-filter');
    const clearBtn = document.getElementById('clear-filters');
    const activeFilters = document.getElementById('active-filters');

    const allPosts = Array.from(postsList.querySelectorAll('.post-card'));

    function getVisiblePosts() {
      return allPosts.filter(item => {
        return item.style.display !== 'none';
      });
    }

    function renderPagination() {
      filteredPosts = getVisiblePosts();
      const totalPages = Math.ceil(filteredPosts.length / POSTS_PER_PAGE);

      if (currentPage > totalPages) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;

      // Hide/show posts based on current page
      filteredPosts.forEach((post, index) => {
        const start = (currentPage - 1) * POSTS_PER_PAGE;
        const end = start + POSTS_PER_PAGE;
        if (index >= start && index < end) {
          post.style.display = '';
        } else {
          post.style.display = 'none';
        }
      });

      // Show/hide no results
      noResults.style.display = filteredPosts.length === 0 ? 'block' : 'none';

      // Render pagination controls
      if (totalPages <= 1) {
        pagination.innerHTML = '';
        return;
      }

      let html = '';

      // Previous button
      html += `<button class="nav-btn" ${currentPage === 1 ? 'disabled' : ''} data-page="${currentPage - 1}">← Previous</button>`;

      // Page numbers
      html += '<div class="page-numbers">';
      for (let i = 1; i <= totalPages; i++) {
        if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
          html += `<button class="page-btn ${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`;
        } else if (i === currentPage - 3 || i === currentPage + 3) {
          html += '<span style="color: var(--text-muted); padding: 0 0.25rem;">...</span>';
        }
      }
      html += '</div>';

      // Next button
      html += `<button class="nav-btn" ${currentPage === totalPages ? 'disabled' : ''} data-page="${currentPage + 1}">Next →</button>`;

      pagination.innerHTML = html;

      // Add click handlers
      pagination.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', () => {
          const page = parseInt(btn.dataset.page);
          if (page && page !== currentPage) {
            currentPage = page;
            renderPagination();
            window.scrollTo({ top: postsList.offsetTop - 100, behavior: 'smooth' });
          }
        });
      });
    }

    function filterPosts() {
      const year = yearFilter.value;
      const month = monthFilter.value;

      allPosts.forEach(item => {
        const matchYear = year === 'all' || item.dataset.year === year;
        const matchMonth = month === 'all' || item.dataset.month === month;

        if (matchYear && matchMonth) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });

      currentPage = 1;
      const hasFilters = year !== 'all' || month !== 'all';
      activeFilters.style.display = hasFilters ? 'flex' : 'none';

      renderPagination();
    }

    yearFilter.addEventListener('change', filterPosts);
    monthFilter.addEventListener('change', filterPosts);
    clearBtn.addEventListener('click', () => {
      yearFilter.value = 'all';
      monthFilter.value = 'all';
      filterPosts();
    });

    // Initial render
    renderPagination();
  });
</script>
