---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SkillBadge from '../components/SkillBadge.astro';
---

<BaseLayout title="About | Naga Siva Poluri" description="Learn more about Naga Siva Poluri - AI Integration Engineer, Data Engineer, Full Stack Developer & Agentic AI Specialist.">
  <div class="page-header">
    <div class="container">
      <span class="section-eyebrow reveal">ABOUT ME</span>
      <h1 class="reveal stagger-1">Engineering the Future of AI & Infrastructure</h1>
      <p class="subtitle reveal stagger-2">Scaling AI systems, designing agentic platforms, and bridging enterprise engineering with intelligent automation.</p>
    </div>
  </div>

  <!-- Main About Section -->
  <section class="about-section">
    <div class="container">
      <div class="about-main card-3d reveal">
        <div class="about-layout">
          <div class="about-sidebar">
            <div class="about-avatar">
              <div class="avatar-placeholder">NSP</div>
              <div class="pulse-badge">
                <span class="pulse-dot"></span>
                <span>AI & Integration Specialist</span>
              </div>
            </div>
            <div class="quick-facts card-3d">
              <h3>Quick Stats</h3>
              <ul class="stats-list">
                <li><strong>Focus:</strong> AI/ML Integration, RAG, Agentic AI</li>
                <li><strong>Location:</strong> Singapore</li>
                <li><strong>Current Role:</strong> AI Integration Engineer @ LTA Singapore</li>
                <li><strong>Education:</strong> MBA (SMU), B.E. EEE (Anna University)</li>
                <li><strong>Experience:</strong> 15+ Years</li>
              </ul>
            </div>
          </div>
          <div class="about-content">
            <div class="narrative-section">
              <span class="section-eyebrow">THE MISSION</span>
              <h2>Bridging Enterprise Systems with Intelligent Automation</h2>
              <div class="about-bio">
                <p>
                  I operate at the intersection of enterprise engineering and artificial intelligence. As an <strong>AI Integration Engineer at LTA Singapore</strong>, I design, build, and optimize intelligent systems that power Singapore's transport infrastructure — from ERP2 tolling systems to fare settlement platforms.
                </p>
                <p>
                  My engineering journey spans over a decade, crossing the boundaries of <strong>Full-Stack Development</strong>, <strong>Data Engineering</strong>, and <strong>Agentic AI</strong>. I've built enterprise RAG platforms for banking, designed AI-powered workflows for government agencies, and led technical transformations across Singapore's financial sector.
                </p>
                <p>
                  With an MBA from <strong>SMU Hyderabad</strong> and a B.E. in Electrical & Electronics Engineering from <strong>Anna University</strong>, I bring a rare synthesis of deep technical expertise and business acumen. I don't just write code — I architect intelligent systems that solve real enterprise problems.
                </p>
              </div>
              <div class="about-buttons">
                <a href="/resume" class="btn btn-primary">Explore My Resume</a>
                <a href="/contact" class="btn btn-secondary">Discuss a Project →</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Pillars -->
  <section class="pillars-section">
    <div class="container">
      <SectionHeader
        eyebrow="CORE FOCUS"
        title="My Architectural Pillars"
        desc="Practical expertise designed for high-availability, compute-heavy, and intelligent applications."
      />
      <div class="pillars-grid">
        <div class="pillar-card card-3d reveal stagger-1">
          <div class="pillar-icon pillar-icon-accent">
            <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="4"/><line x1="1.05" y1="12" x2="7" y2="12"/><line x1="17.01" y1="12" x2="22.95" y2="12"/><line x1="8.5" y1="2" x2="8.5" y2="5.5"/><line x1="15.5" y1="2" x2="15.5" y2="5.5"/><line x1="8.5" y1="18.5" x2="8.5" y2="22"/><line x1="15.5" y1="18.5" x2="15.5" y2="22"/></svg>
          </div>
          <h3>AI, LLMs & Agentic Systems</h3>
          <p>Architecting production RAG platforms, designing agentic pipelines, and integrating LLMs into enterprise workflows. From prompt engineering to full-stack AI applications.</p>
        </div>
        <div class="pillar-card card-3d reveal stagger-2">
          <div class="pillar-icon pillar-icon-teal">
            <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/><line x1="20" y1="6" x2="20.01" y2="6"/><line x1="20" y1="18" x2="20.01" y2="18"/></svg>
          </div>
          <h3>Full Stack & Cloud Engineering</h3>
          <p>Building end-to-end enterprise solutions with Java, Python, React, and cloud-native architectures. Expertise in microservices, APIs, and distributed systems.</p>
        </div>
        <div class="pillar-card card-3d reveal stagger-3">
          <div class="pillar-icon pillar-icon-coral">
            <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3>Data Engineering & Integration</h3>
          <p>Designing data pipelines, ETL processes, and real-time streaming architectures. Connecting disparate enterprise systems into cohesive data-driven platforms.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What I'm Up To -->
  <section class="exploration-section">
    <div class="container">
      <div class="exploration-card card-3d reveal">
        <div class="exploration-layout">
          <div class="exploration-text">
            <span class="section-eyebrow">CURRENT FRONTIERS</span>
            <h2>What I'm Exploring</h2>
            <p>I believe in constant iteration. These are the domains where I am currently pushing boundaries:</p>
            <ul class="exploration-list">
              <li><strong>Multi-Agent Systems:</strong> Building autonomous developer platforms that diagnose system states and self-heal.</li>
              <li><strong>Enterprise RAG:</strong> Designing production retrieval-augmented generation systems for banking and government.</li>
              <li><strong>Agentic Workflows:</strong> Creating AI agents that automate complex enterprise processes end-to-end.</li>
            </ul>
          </div>
          <div class="exploration-quote">
            <div class="quote-content">
              <span class="quote-mark">"</span>
              <p>The boundary between engineering and imagination is shrinking. As AI moves from static models to agentic, autonomous execution, the bottleneck is no longer code — it's the platform architecture that supports it.</p>
              <span class="quote-author">— Naga Siva Poluri</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-section { padding: 2rem 0 6rem; }

  .about-main { padding: 3rem; }

  .about-layout {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 3rem;
  }

  .about-avatar {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .avatar-placeholder {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: var(--gradient-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 800;
    color: #fff;
    margin: 0 auto 1rem;
    position: relative;
    animation: morph 8s ease-in-out infinite;
  }

  .pulse-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    border-radius: var(--radius-full);
    background: rgba(20, 184, 166, 0.1);
    border: 1px solid rgba(20, 184, 166, 0.25);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--teal-light);
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--teal);
    animation: glow-pulse 2s ease-in-out infinite;
  }

  .quick-facts h3 {
    font-size: 1rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .stats-list {
    list-style: none;
    padding: 0;
  }

  .stats-list li {
    padding: 0.5rem 0;
    font-size: 0.88rem;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border);
  }

  .stats-list li:last-child { border-bottom: none; }
  .stats-list li strong { color: var(--accent-light); }

  .about-content .section-eyebrow { text-align: left; }

  .about-content h2 {
    text-align: left;
    margin-bottom: 1.5rem;
    margin-top: 0;
  }

  .about-bio p {
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }

  .about-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .pillars-section { padding: 4rem 0; }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .pillar-card {
    padding: 2rem;
    text-align: center;
  }

  .pillar-icon {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
  }

  .pillar-icon-accent { background: rgba(139, 92, 246, 0.12); color: var(--accent-light); }
  .pillar-icon-teal { background: rgba(20, 184, 166, 0.12); color: var(--teal-light); }
  .pillar-icon-coral { background: rgba(249, 115, 22, 0.12); color: var(--coral); }

  .pillar-card h3 { font-size: 1.15rem; margin-bottom: 0.75rem; }
  .pillar-card p { font-size: 0.92rem; color: var(--text-muted); line-height: 1.7; margin: 0; }

  .exploration-section { padding: 4rem 0; }

  .exploration-card { padding: 3rem; overflow: hidden; }

  .exploration-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .exploration-text .section-eyebrow { margin-bottom: 0.5rem; }
  .exploration-text h2 { margin-bottom: 1rem; margin-top: 0; font-size: 1.5rem; }

  .exploration-list {
    list-style: none;
    padding: 0;
    margin-top: 1rem;
  }

  .exploration-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .exploration-list li:last-child { border-bottom: none; }

  .quote-content {
    background: rgba(139, 92, 246, 0.05);
    border: 1px solid rgba(139, 92, 246, 0.15);
    border-radius: var(--radius-lg);
    padding: 2rem;
    position: relative;
  }

  .quote-mark {
    font-size: 4rem;
    line-height: 1;
    color: var(--accent);
    font-family: Georgia, serif;
    display: block;
    margin-bottom: -1rem;
  }

  .quote-content p {
    font-style: italic;
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.8;
  }

  .quote-author {
    display: block;
    margin-top: 1rem;
    font-weight: 600;
    color: var(--accent-light);
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .about-layout { grid-template-columns: 1fr; }
    .pillars-grid { grid-template-columns: 1fr; }
    .exploration-layout { grid-template-columns: 1fr; }
  }
</style>
