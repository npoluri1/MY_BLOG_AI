---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
---

<BaseLayout title="About | Naga Siva Poluri" description="Learn more about Naga Siva Poluri - AI Integration Engineer, Data Engineer, Full Stack Developer & Agentic AI Specialist.">
  <section class="about-hero">
    <div class="container">
      <span class="section-eyebrow reveal">ABOUT ME</span>
      <h1 class="reveal stagger-1">Engineering the Future of AI & Infrastructure</h1>
      <p class="about-subtitle reveal stagger-2">Scaling AI systems, designing agentic platforms, and bridging enterprise engineering with intelligent automation.</p>
    </div>
  </section>

  <section class="about-main">
    <div class="container">
      <div class="about-grid">
        <aside class="about-sidebar reveal">
          <div class="avatar">
            <span class="avatar-initials">NSP</span>
          </div>
          <div class="avatar-badge">
            <span class="badge-dot"></span>
            <span>AI & Integration Specialist</span>
          </div>
          <div class="quick-stats">
            <h3>Quick Stats</h3>
            <dl class="stats-list">
              <div class="stat-item">
                <dt>Focus</dt>
                <dd>AI/ML Integration, RAG, Agentic AI</dd>
              </div>
              <div class="stat-item">
                <dt>Location</dt>
                <dd>Singapore</dd>
              </div>
              <div class="stat-item">
                <dt>Current Role</dt>
                <dd>AI Integration Engineer @ LTA Singapore</dd>
              </div>
              <div class="stat-item">
                <dt>Education</dt>
                <dd>MBA (SMU), B.E. EEE (Anna University)</dd>
              </div>
              <div class="stat-item">
                <dt>Experience</dt>
                <dd>15+ Years</dd>
              </div>
            </dl>
          </div>
        </aside>

        <div class="about-content reveal stagger-1">
          <span class="section-eyebrow">THE MISSION</span>
          <h2>Bridging Enterprise Systems with Intelligent Automation</h2>
          <div class="bio">
            <p>
              I operate at the intersection of enterprise engineering and artificial intelligence. As an <strong>AI Integration Engineer at LTA Singapore</strong>, I design, build, and optimize intelligent systems that power Singapore's transport infrastructure — from ERP2 tolling systems to fare settlement platforms.
            </p>
            <p>
              My engineering journey spans over a decade, crossing the boundaries of <strong>Full-Stack Development</strong>, <strong>Data Engineering</strong>, and <strong>Agentic AI</strong>. I've built enterprise RAG platforms for banking, designed AI-powered workflows for government agencies, and led technical transformations across Singapore's financial sector.
            </p>
            <p>
              With an MBA from <strong>SMU Hyderabad</strong> and a B.E. in Electrical & Electronics Engineering from <strong>Anna University</strong>, I bring a rare synthesis of deep technical expertise and business acumen. I don't just write code — I architect intelligent systems that solve real enterprise problems.
            </p>
          </div>
          <div class="about-actions">
            <a href="/resume" class="btn btn-primary">Explore My Resume</a>
            <a href="/contact" class="btn btn-secondary">Discuss a Project →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pillars-section">
    <div class="container">
      <SectionHeader
        eyebrow="CORE FOCUS"
        title="My Architectural Pillars"
        desc="Practical expertise designed for high-availability, compute-heavy, and intelligent applications."
      />
      <div class="pillars-grid">
        <article class="pillar-card reveal stagger-1">
          <div class="pillar-icon accent">
            <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="4"/><line x1="1.05" y1="12" x2="7" y2="12"/><line x1="17.01" y1="12" x2="22.95" y2="12"/><line x1="8.5" y1="2" x2="8.5" y2="5.5"/><line x1="15.5" y1="2" x2="15.5" y2="5.5"/><line x1="8.5" y1="18.5" x2="8.5" y2="22"/><line x1="15.5" y1="18.5" x2="15.5" y2="22"/></svg>
          </div>
          <h3>AI, LLMs & Agentic Systems</h3>
          <p>Architecting production RAG platforms, designing agentic pipelines, and integrating LLMs into enterprise workflows. From prompt engineering to full-stack AI applications.</p>
        </article>
        <article class="pillar-card reveal stagger-2">
          <div class="pillar-icon teal">
            <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/><line x1="20" y1="6" x2="20.01" y2="6"/><line x1="20" y1="18" x2="20.01" y2="18"/></svg>
          </div>
          <h3>Full Stack & Cloud Engineering</h3>
          <p>Building end-to-end enterprise solutions with Java, Python, React, and cloud-native architectures. Expertise in microservices, APIs, and distributed systems.</p>
        </article>
        <article class="pillar-card reveal stagger-3">
          <div class="pillar-icon coral">
            <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3>Data Engineering & Integration</h3>
          <p>Designing data pipelines, ETL processes, and real-time streaming architectures. Connecting disparate enterprise systems into cohesive data-driven platforms.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="frontiers-section">
    <div class="container">
      <div class="frontiers-grid">
        <div class="frontiers-text reveal">
          <span class="section-eyebrow">CURRENT FRONTIERS</span>
          <h2>What I'm Exploring</h2>
          <p>I believe in constant iteration. These are the domains where I am currently pushing boundaries:</p>
          <ul class="frontiers-list">
            <li>
              <strong>Multi-Agent Systems</strong>
              <span>Building autonomous developer platforms that diagnose system states and self-heal.</span>
            </li>
            <li>
              <strong>Enterprise RAG</strong>
              <span>Designing production retrieval-augmented generation systems for banking and government.</span>
            </li>
            <li>
              <strong>Agentic Workflows</strong>
              <span>Creating AI agents that automate complex enterprise processes end-to-end.</span>
            </li>
          </ul>
        </div>
        <blockquote class="frontiers-quote reveal stagger-1">
          <p>"The boundary between engineering and imagination is shrinking. As AI moves from static models to agentic, autonomous execution, the bottleneck is no longer code — it's the platform architecture that supports it."</p>
          <cite>— Naga Siva Poluri</cite>
        </blockquote>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    padding: 6rem 0 2rem;
    text-align: center;
  }

  .about-subtitle {
    font-size: 1.15rem;
    color: var(--text-secondary);
    max-width: 640px;
    margin: 1rem auto 0;
    line-height: 1.7;
  }

  .about-main {
    padding: 3rem 0 5rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .about-sidebar {
    position: sticky;
    top: calc(var(--header-height) + 2rem);
    text-align: center;
  }

  .avatar {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: var(--gradient-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }

  .avatar-initials {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.05em;
  }

  .avatar-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    background: rgba(20, 184, 166, 0.08);
    border: 1px solid rgba(20, 184, 166, 0.2);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--teal-light);
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--teal);
  }

  .quick-stats {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-align: left;
  }

  .quick-stats h3 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .stats-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .stat-item {
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border);
  }

  .stat-item:last-child {
    border-bottom: none;
  }

  .stat-item dt {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .stat-item dd {
    font-size: 0.88rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  .about-content .section-eyebrow {
    text-align: left;
  }

  .about-content h2 {
    font-size: 1.8rem;
    margin: 0.5rem 0 1.5rem;
    line-height: 1.3;
  }

  .bio p {
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }

  .bio strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .about-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.5rem;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-sans);
    cursor: pointer;
    transition: var(--transition-fast);
    text-decoration: none;
  }

  .btn-primary {
    background: var(--gradient-accent);
    color: #fff;
    border: none;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(139, 92, 246, 0.35);
    color: #fff;
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent-light);
  }

  .pillars-section {
    padding: 4rem 0;
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .pillar-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
    transition: var(--transition-fast);
  }

  .pillar-card:hover {
    border-color: var(--border-hover);
    background: var(--bg-card-hover);
  }

  .pillar-icon {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
  }

  .pillar-icon.accent {
    background: rgba(139, 92, 246, 0.1);
    color: var(--accent-light);
  }

  .pillar-icon.teal {
    background: rgba(20, 184, 166, 0.1);
    color: var(--teal-light);
  }

  .pillar-icon.coral {
    background: rgba(249, 115, 22, 0.1);
    color: var(--coral);
  }

  .pillar-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  .pillar-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .frontiers-section {
    padding: 4rem 0 6rem;
  }

  .frontiers-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .frontiers-text .section-eyebrow {
    margin-bottom: 0.5rem;
  }

  .frontiers-text h2 {
    font-size: 1.6rem;
    margin: 0.5rem 0 1rem;
  }

  .frontiers-text > p {
    font-size: 1rem;
    color: var(--text-secondary);
  }

  .frontiers-list {
    list-style: none;
    padding: 0;
    margin-top: 1.5rem;
  }

  .frontiers-list li {
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
  }

  .frontiers-list li:last-child {
    border-bottom: none;
  }

  .frontiers-list li strong {
    display: block;
    font-size: 0.95rem;
    margin-bottom: 0.2rem;
  }

  .frontiers-list li span {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .frontiers-quote {
    background: rgba(139, 92, 246, 0.04);
    border: 1px solid rgba(139, 92, 246, 0.12);
    border-radius: var(--radius-lg);
    padding: 2rem;
    margin: 0;
    position: relative;
  }

  .frontiers-quote::before {
    content: '\201C';
    font-size: 4rem;
    line-height: 1;
    color: var(--accent);
    font-family: Georgia, serif;
    position: absolute;
    top: 1rem;
    left: 1.5rem;
  }

  .frontiers-quote p {
    font-style: italic;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.8;
    padding-top: 2rem;
    margin: 0;
  }

  .frontiers-quote cite {
    display: block;
    margin-top: 1rem;
    font-style: normal;
    font-weight: 600;
    color: var(--accent-light);
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .about-hero { padding-top: 4rem; }

    .about-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .about-sidebar {
      position: static;
    }

    .pillars-grid {
      grid-template-columns: 1fr;
    }

    .frontiers-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
