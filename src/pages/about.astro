---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
---

<BaseLayout
  title="About | Naga Siva Poluri"
  description="AI Integration Engineer, Data Engineer, Full Stack Developer & Agentic AI Specialist. 15+ years across Singapore's Government, Banking, Insurance, Transport, and Fintech sectors. Currently leading AI at LTA Singapore."
>
  <section class="about-hero">
    <div class="container">
      <span class="section-eyebrow reveal">ABOUT ME</span>
      <h1 class="reveal stagger-1">
        Engineering the Future of <span class="hero-accent">AI</span> &amp; <span class="hero-accent">Enterprise Systems</span>
      </h1>
      <p class="about-subtitle reveal stagger-2">
        Scaling agentic AI, RAG platforms, and data infrastructure for Singapore's most demanding enterprise environments.
      </p>
      <div class="hero-contact reveal stagger-3">
        <a href="tel:+6581765178" class="contact-pill">📞 +65 81765178</a>
        <a href="mailto:npoluri1@gmail.com" class="contact-pill">✉ npoluri1@gmail.com</a>
        <span class="contact-pill contact-pill-static">📍 Singapore</span>
        <span class="contact-pill contact-pill-static contact-pill-open">Open to Global Opportunities</span>
      </div>
    </div>
  </section>

  <section class="about-main">
    <div class="container">
      <div class="about-grid">
        <aside class="about-sidebar reveal">
          <div class="avatar">
            <span class="avatar-initials">NSP</span>
          </div>
          <div class="avatar-badge">
            <span class="badge-dot"></span>
            <span>AI &amp; Integration Specialist</span>
          </div>

          <div class="quick-stats">
            <h3>Quick Stats</h3>
            <dl class="stats-list">
              <div class="stat-item">
                <dt>Experience</dt>
                <dd>15+ Years Enterprise Delivery</dd>
              </div>
              <div class="stat-item">
                <dt>Current Role</dt>
                <dd>AI Integration Engineer @ LTA Singapore (via Deziretech)</dd>
              </div>
              <div class="stat-item">
                <dt>Focus</dt>
                <dd>Agentic AI · RAG · Data Engineering · Microservices</dd>
              </div>
              <div class="stat-item">
                <dt>Location</dt>
                <dd>Singapore (Singapore EP holder)</dd>
              </div>
              <div class="stat-item">
                <dt>Education</dt>
                <dd>MBA (SMU, Hyderabad) · B.E. EEE (Anna University)</dd>
              </div>
              <div class="stat-item">
                <dt>Availability</dt>
                <dd>AI, Banking, FinTech, Cloud roles globally</dd>
              </div>
            </dl>
          </div>

          <a href="/resume" class="resume-btn">View Full Resume →</a>
        </aside>

        <div class="about-content reveal stagger-1">
          <span class="section-eyebrow">PROFESSIONAL SUMMARY</span>
          <h2>Bridging Enterprise Systems with Intelligent Automation</h2>

          <div class="bio">
            <p>
              I'm a forward-thinking <strong>AI Integration Engineer, Data Engineer</strong> and
              <strong>Full Stack Developer</strong> with 15+ years of enterprise solution delivery across Singapore's
              top-tier Government, Banking, Insurance, Transport, and Fintech sectors.
            </p>
            <p>
              Currently I lead AI-powered transformation for <strong>Singapore's Land Transport Authority (LTA)</strong> —
              delivering intelligent Payments, FDMS, TAPS, Data Analytics, and Fare Management systems serving
              millions of daily commuters.
            </p>
            <p>
              My technical depth spans <strong>Agentic AI</strong> (LangGraph, CrewAI, MCP, OpenClaw-pattern
              architectures), RAG pipelines, LLM orchestration (Claude API, OpenAI, AWS Bedrock),
              <strong>Data Science</strong> (Scikit-learn, XGBoost, MLflow, SageMaker),
              <strong>Data Engineering</strong> (Apache Spark, PySpark, Airflow, Snowflake, dbt, Kafka),
              Java, Python, Spring Boot, ReactJS, Microservices, and Cloud (AWS / OpenShift).
            </p>
            <p>
              I bridge cutting-edge AI capabilities with robust, scalable production data engineering —
              turning research-grade models into systems that survive daily enterprise traffic.
            </p>
          </div>

          <div class="about-actions">
            <a href="/portfolio" class="btn btn-primary">Featured Projects</a>
            <a href="/contact" class="btn btn-secondary">Discuss a Project →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick role timeline preview -->
  <section class="role-timeline-section">
    <div class="container">
      <SectionHeader
        eyebrow="CAREER TRAJECTORY"
        title="Where I've Made Impact"
        desc="Five stops across Singapore's top-tier enterprise environments, with parallel portfolio work in agentic AI and RAG."
      />
      <div class="role-timeline">
        <div class="role-stop reveal stagger-1">
          <span class="role-when">Nov 2025 — Present</span>
          <h3>AI Integration Engineer</h3>
          <p class="role-where">Land Transport Authority (LTA) · via Deziretech</p>
          <p class="role-summary">Leading end-to-end AI integration across LTA's critical transport payments systems — FDMS, TAPS, ABT, Fare Display — for millions of daily MRT/LRT/Bus commuters.</p>
        </div>
        <div class="role-stop reveal stagger-2">
          <span class="role-when">Sep 2024 — Jul 2025</span>
          <h3>AI Integration Engineer</h3>
          <p class="role-where">Bank of Singapore (BOS) · via HCL Technologies</p>
          <p class="role-summary">Architected AI-powered Loan Processing Platform with LLM document analysis, automated KYC, fraud detection on AWS Bedrock &amp; LangChain for private banking.</p>
        </div>
        <div class="role-stop reveal stagger-3">
          <span class="role-when">Jan 2023 — Sep 2024</span>
          <h3>Senior Lead Engineer</h3>
          <p class="role-where">United Overseas Bank (UOB) · via HCL Technologies</p>
          <p class="role-summary">Led Agile delivery of Wealth Management &amp; Open Banking platforms at UOB TMRW; built 50M+ daily transaction data platform with Spark, Kafka, Snowflake &amp; dbt.</p>
        </div>
        <div class="role-stop reveal stagger-4">
          <span class="role-when">Aug 2022 — Jan 2023</span>
          <h3>Technical Lead</h3>
          <p class="role-where">Sing Life (with Aviva) · via Recruit Express</p>
          <p class="role-summary">Led Payments &amp; Collections microservices with DBS PayNow/eDDA for Singapore's leading digital insurer.</p>
        </div>
        <div class="role-stop reveal stagger-5">
          <span class="role-when">Aug 2021 — Aug 2022</span>
          <h3>Full Stack Developer — OCBC</h3>
          <p class="role-where">OCBC Bank · via Recruit Express</p>
          <p class="role-summary">Migrated legacy .NET banking to Spring Boot microservices; digital banking, payments, fund transfers, tokenization.</p>
        </div>
      </div>
      <div class="timeline-cta">
        <a href="/resume" class="btn btn-secondary">See the full 15-year trajectory →</a>
      </div>
    </div>
  </section>

  <!-- Pillars / Tech Stacks -->
  <section class="pillars-section">
    <div class="container">
      <SectionHeader
        eyebrow="CORE FOCUS"
        title="My Architectural Pillars"
        desc="Practical expertise considered for high-availability, compute-heavy, and intelligent applications."
      />
      <div class="pillars-grid">
        <article class="pillar-card reveal stagger-1">
          <div class="pillar-icon accent">
            <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none"><path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.93 19.07l2.83-2.83"/><path d="M16.24 7.76l2.83-2.83"/></svg>
          </div>
          <h3>LLMs &amp; Agentic AI</h3>
          <p>Building production multi-agent platforms, RAG systems, and LLM orchestration. Deep hands-on with LangGraph, CrewAI, MCP, Claude API, OpenAI, AWS Bedrock.</p>
          <div class="pillar-tech">
            <span>LangGraph</span><span>Claude</span><span>OpenAI</span><span>CrewAI</span><span>MCP</span><span>RAG</span>
          </div>
        </article>
        <article class="pillar-card reveal stagger-2">
          <div class="pillar-icon teal">
            <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
          </div>
          <h3>Data Engineering</h3>
          <p>Designing pipelines that move billions of records. Spark, Airflow, Snowflake, dbt, Kafka, Glue — built for AML/CDD, IFRS, and high-volume batch + streaming workloads.</p>
          <div class="pillar-tech">
            <span>Spark</span><span>Airflow</span><span>Snowflake</span><span>dbt</span><span>Kafka</span><span>dbt</span>
          </div>
        </article>
        <article class="pillar-card reveal stagger-3">
          <div class="pillar-icon coral">
            <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3>ML &amp; Data Science</h3>
          <p>From credit risk scoring (XGBoost, 0.87 AUC) to fraud detection (Isolation Forest + LightGBM ensembles) — production ML on AWS SageMaker with MLflow lineage.</p>
          <div class="pillar-tech">
            <span>Scikit-learn</span><span>XGBoost</span><span>SageMaker</span><span>MLflow</span><span>LightGBM</span>
          </div>
        </article>
        <article class="pillar-card reveal stagger-4">
          <div class="pillar-icon accent">
            <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3>Backend &amp; Microservices</h3>
          <p>Java 8/11/17, Spring Boot, Spring Batch, Spring Cloud Gateway, Spring AI, Kafka, OpenShift. Building the rails enterprise systems run on.</p>
          <div class="pillar-tech">
            <span>Spring Boot</span><span>Kafka</span><span>OpenShift</span><span>Spring AI</span><span>Java</span><span>Python</span>
          </div>
        </article>
        <article class="pillar-card reveal stagger-5">
          <div class="pillar-icon teal">
            <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>
          </div>
          <h3>Cloud (AWS)</h3>
          <p>Bedrock, SageMaker, EC2, S3, Glue, EMR, Lambda, Cognito, Redshift, API Gateway. Production-grade cloud-native architecture for the public sector.</p>
          <div class="pillar-tech">
            <span>Bedrock</span><span>SageMaker</span><span>Glue</span><span>Redshift</span><span>Lambda</span>
          </div>
        </article>
        <article class="pillar-card reveal stagger-6">
          <div class="pillar-icon coral">
            <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3>Frontend &amp; APIs</h3>
          <p>ReactJS, React Native, Angular v2–16+, TypeScript, REST, gRPC, SOAP. Bridging modern UX into conservative enterprise frameworks.</p>
          <div class="pillar-tech">
            <span>React</span><span>Angular</span><span>TypeScript</span><span>REST</span><span>gRPC</span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Frontiers -->
  <section class="frontiers-section">
    <div class="container">
      <div class="frontiers-grid">
        <div class="frontiers-text reveal">
          <span class="section-eyebrow">CURRENT FRONTIERS</span>
          <h2>What I'm Building Now</h2>
          <p>I believe in shipping. These are the systems I have in production or actively building on the side:</p>
          <ul class="frontiers-list">
            <li>
              <strong>Agentic AI Assistant Platform (2025–2026)</strong>
              <span>Self-built production-grade, message-driven multi-agent platform. Telegram/WhatsApp ingest, LangGraph orchestration, MCP tool discovery, persistent memory, WebSocket streaming, Guardrails AI for security, LangSmith tracing.</span>
            </li>
            <li>
              <strong>Enterprise RAG Intelligence Platform (2025)</strong>
              <span>Hybrid RAG (Pinecone + BM25 + Cohere rerank) for Singapore financial/legal document AI. 94% relevancy vs 71% naive baseline. LoRA fine-tuned embeddings on MAS/SGX corpus.</span>
            </li>
            <li>
              <strong>LTA Transport AI (2025–)</strong>
              <span>AI-assisted fare validation, ML anomaly detection for payment fraud, RAG-based inquiry layer that automates 60% of fare disputes without human intervention.</span>
            </li>
          </ul>
        </div>
        <blockquote class="frontiers-quote reveal stagger-1">
          <p>"AI is no longer a feature you bolt on. It's an operating system layer. The companies that understand this will dominate their markets. The ones that don't will be disrupted."</p>
          <cite>— Naga Siva Poluri</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Languages -->
  <section class="languages-section">
    <div class="container">
      <SectionHeader
        eyebrow="LANGUAGES &amp; CITIZENSHIP"
        title="Global Mobility"
        desc="Singapore EP holder. Available for Banking, FinTech, AI &amp; Cloud opportunities globally."
      />
      <div class="languages-grid">
        <div class="lang-card reveal stagger-1">
          <span class="lang-flag">🇬🇧</span>
          <h4>English</h4>
          <p>Professional working proficiency</p>
        </div>
        <div class="lang-card reveal stagger-2">
          <span class="lang-flag">🇮🇳</span>
          <h4>Hindi</h4>
          <p>Native / Business fluent</p>
        </div>
        <div class="lang-card reveal stagger-3">
          <span class="lang-flag">🇮🇳</span>
          <h4>Telugu</h4>
          <p>Native</p>
        </div>
        <div class="lang-card reveal stagger-4">
          <span class="lang-flag">🇮🇳</span>
          <h4>Tamil</h4>
          <p>Conversational</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    padding: 6rem 0 2rem;
    text-align: center;
    position: relative;
  }
  .about-hero::before {
    content: '';
    position: absolute;
    top: 30%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60%;
    max-width: 900px;
    height: 60%;
    background: radial-gradient(ellipse at center, rgba(139, 92, 246, 0.14) 0%, rgba(20, 184, 166, 0.05) 40%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .about-hero > .container { position: relative; z-index: 1; }

  .about-hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    margin-bottom: 0.85rem;
    line-height: 1.15;
    letter-spacing: -0.025em;
  }
  .hero-accent {
    background: linear-gradient(135deg, var(--accent-light), var(--teal-light));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .about-subtitle {
    font-size: 1.05rem;
    color: var(--text-secondary);
    max-width: 720px;
    margin: 0.5rem auto 1.75rem;
    line-height: 1.7;
  }
  .hero-contact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }
  .contact-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.95rem;
    border-radius: var(--radius-full);
    background: rgba(139, 92, 246, 0.06);
    border: 1px solid rgba(139, 92, 246, 0.18);
    color: var(--text-secondary);
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition-fast);
  }
  a.contact-pill:hover {
    border-color: var(--accent);
    color: var(--accent-light);
    transform: translateY(-1px);
  }
  .contact-pill-static { cursor: default; }
  .contact-pill-open {
    background: rgba(20, 184, 166, 0.08);
    border-color: rgba(20, 184, 166, 0.25);
    color: var(--teal-light);
  }

  .about-main { padding: 3rem 0 5rem; }
  .about-grid {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 4rem;
    align-items: start;
  }
  .about-sidebar {
    position: sticky;
    top: calc(var(--header-height) + 2rem);
    text-align: center;
  }
  .avatar {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: var(--gradient-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }
  .avatar-initials {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.05em;
  }
  .avatar-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    background: rgba(20, 184, 166, 0.08);
    border: 1px solid rgba(20, 184, 166, 0.2);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--teal-light);
    margin-bottom: 1.5rem;
  }
  .badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--teal);
  }
  .quick-stats {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-align: left;
    margin-bottom: 1rem;
  }
  .quick-stats h3 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }
  .stats-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .stat-item {
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border);
  }
  .stat-item:last-child { border-bottom: none; }
  .stat-item dt {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: 0.2rem;
  }
  .stat-item dd {
    font-size: 0.88rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
  }
  .resume-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.25rem;
    margin-top: 0.5rem;
    background: var(--gradient-accent);
    color: #fff;
    border-radius: var(--radius-sm);
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
    transition: var(--transition-fast);
  }
  .resume-btn:hover {
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(139, 92, 246, 0.35);
  }

  .about-content .section-eyebrow { text-align: left; }
  .about-content h2 {
    font-size: 1.8rem;
    margin: 0.5rem 0 1.5rem;
    line-height: 1.3;
  }
  .bio p {
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }
  .bio strong { color: var(--text-primary); font-weight: 600; }
  .about-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.5rem;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-sans);
    cursor: pointer;
    transition: var(--transition-fast);
    text-decoration: none;
  }
  .btn-primary {
    background: var(--gradient-accent);
    color: #fff;
    border: none;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(139, 92, 246, 0.35);
    color: #fff;
  }
  .btn-secondary {
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border);
  }
  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent-light);
  }

  /* Role Timeline */
  .role-timeline-section {
    padding: 4rem 0;
    border-top: 1px solid var(--border);
  }
  .role-timeline {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 3rem;
  }
  .role-stop {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    transition: var(--transition-fast);
  }
  .role-stop:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }
  .role-when {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--accent-light);
    background: rgba(139, 92, 246, 0.1);
    padding: 0.2rem 0.65rem;
    border-radius: var(--radius-full);
    margin-bottom: 0.7rem;
  }
  .role-stop h3 {
    font-size: 1.1rem;
    margin-bottom: 0.35rem;
    color: var(--text-primary);
  }
  .role-where {
    font-size: 0.85rem;
    color: var(--teal-light);
    margin-bottom: 0.7rem;
    font-weight: 600;
  }
  .role-summary {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0;
  }
  .timeline-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* Pillars */
  .pillars-section { padding: 4rem 0; }
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .pillar-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: var(--transition-fast);
  }
  .pillar-card:hover {
    border-color: var(--border-hover);
    background: var(--bg-card-hover);
  }
  .pillar-icon {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .pillar-icon.accent { background: rgba(139, 92, 246, 0.1); color: var(--accent-light); }
  .pillar-icon.teal { background: rgba(20, 184, 166, 0.1); color: var(--teal-light); }
  .pillar-icon.coral { background: rgba(249, 115, 22, 0.1); color: var(--coral); }
  .pillar-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
