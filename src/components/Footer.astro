---

<footer>
  <div class="container footer-content">
    <div class="footer-social">
      {socialLinks.map(link => (
        <a href={link.url} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={link.name}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d={link.icon}/></svg>
          <span>{link.name}</span>
        </a>
      ))}
    </div>
    <div class="footer-bottom">
      <p>&copy; {year} Naga Siva Poluri. Built with Astro & Vanilla CSS. <span class="dot-sep">·</span> Curated 3D experience.</p>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: 4rem;
    padding: 3rem 0 2rem;
    border-top: 1px solid var(--border);
  }

  .footer-content { text-align: center; }
  .footer-social {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
    transition: var(--transition-fast);
  }

  .social-link:hover {
    color: var(--accent-light);
  }

  .footer-bottom {
    color: var(--text-muted);
    font-size: 0.82rem;
  }
  .dot-sep { opacity: 0.5; padding: 0 0.3rem; }
</style>
